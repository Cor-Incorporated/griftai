---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@/config';
import { corCta } from '@/lib/cor-cta';

const contactUrl = corCta.teamBeta('grift-pricing');

const betaPlans = [
  {
    name: 'Grift Team Beta',
    price: '月額5万円を基本に個別案内',
    target: '2〜10人の受託チーム',
    description:
      'チーム内で、担当者に依存しすぎない見積プロセスを作るためのプランです。利用範囲・チーム規模・サポート内容に応じて個別にご案内します。',
    cta: 'Team Betaについて相談する',
    href: corCta.teamBeta('grift-pricing-team-beta'),
    features: [
      'チームワークスペース',
      '案件前提の整理',
      '参考見積レポート',
      'GitHub実績の参照',
      'レビュー履歴管理',
    ],
  },
  {
    name: 'Grift Paid Trial',
    price: '3ヶ月15万円を基本に個別案内',
    target: '小規模受託チーム',
    description:
      'まずは実際のプロジェクトで、見積根拠の整理とナレッジ蓄積を試してみたいチーム向けのトライアルプランです。利用範囲・サポート内容に応じて個別にご案内します。',
    cta: '有料トライアルを相談する',
    href: corCta.paidTrial('grift-pricing-paid-trial'),
    features: [
      '実案件での利用検証',
      '月1回ヒアリング',
      '改善フィードバック',
      '見積根拠メモ',
      'ナレッジ蓄積支援',
    ],
  },
  {
    name: 'Grift Estimate Audit',
    price: '100万円を基本に個別見積',
    target: '発注企業',
    description:
      '提出された見積もりの妥当性を検討するための判断材料として、AIと実装者の視点で、見積の前提・技術リスク・工数妥当性を整理します。',
    cta: 'Estimate Auditについて相談する',
    href: corCta.estimateAudit('grift-pricing-estimate-audit'),
    features: [
      '見積前提の整理',
      '技術リスク確認',
      '工数妥当性の検討',
      '相見積もり前の質問整理',
      '稟議前の判断材料化',
    ],
  },
];

const plannedFeatures = [
  'マルチプロバイダ市場調査（複数AIソースによる相場の参考比較）',
  'Go/No-Goスコアリング（提案前の判断材料整理）',
  'Linear / GitHub連携（承認済み見積からタスク候補を整理）',
  'チーム共有と権限管理',
];

const selectionGuides = [
  {
    condition: '継続的に見積を作る受託チーム',
    recommendation: 'Grift Team Beta',
    body: '月額5万円を基本に、チームワークスペース、案件見積、レポート出力、GitHub実績の参照、履歴管理を検証します。',
  },
  {
    condition: 'まず3ヶ月だけ試したい小規模チーム',
    recommendation: 'Grift Paid Trial',
    body: '3ヶ月15万円を基本に、Team Betaの利用検証、月1回ヒアリング、改善フィードバック込みでご案内します。',
  },
  {
    condition: '発注側として見積の前提を見たい',
    recommendation: 'Grift Estimate Audit',
    body: '100万円を基本に、提出された見積の前提、技術リスク、工数妥当性を検討する材料を整理します。',
  },
];

const pricingFaqs = [
  {
    question: '料金はいくらですか？',
    answer:
      'Grift Team Betaは月額5万円を基本に個別案内しています。Paid Trialは3ヶ月15万円、Estimate Auditは100万円を基本に、利用範囲・チーム規模・サポート内容に応じてご案内します。',
  },
  {
    question: 'AIが見積金額を決めるのですか？',
    answer:
      'いいえ。Griftは参考見積と見積根拠を整理するAI見積支援ツールです。最終的な見積金額の決定は人間が行います。',
  },
  {
    question: '正式版の料金はどうなりますか？',
    answer:
      '正式版の料金体系は、ベータ版での利用状況、支払い意思、フィードバックを踏まえて見直す可能性があります。',
  },
  {
    question: '契約前に相談できますか？',
    answer:
      'もちろんです。現在ベータ版として提供範囲を検証中のため、まずはチームの課題や状況をヒアリングし、自分たちの案件で使えるかどうかのご相談から承っております。',
  },
];

const onboardingSteps = [
  {
    title: 'お問い合わせ',
    body: '現在の見積プロセスや課題をお聞かせください',
  },
  {
    title: 'ベータ提供条件のご案内',
    body: '利用イメージに合うか確認し、提供範囲と条件をご案内します',
  },
  {
    title: '利用開始',
    body: '実際の案件で見積根拠の整理をお試しください',
  },
];
---

<MarketingLayout
  title={`料金プラン — 受託開発チームのAI見積支援 | ${siteConfig.name}`}
  titleTag="料金プラン｜Grift Team Beta"
  ogTitle="Grift Team Betaの料金｜Grift"
  description="Griftは受託開発チームの見積根拠を整理するAI見積支援ツールです。Team Betaは月額5万円、Paid Trialは3ヶ月15万円、Estimate Auditは100万円を基本に個別案内しています。"
  faqItems={pricingFaqs}
>
  <PageHeader
    title="Team Beta / Pricing"
    subtitle="見積根拠を、チームの資産にするための有料β。利用範囲・チーム規模・サポート内容に応じて個別にご案内します。"
  />

  <section class="bg-background py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-5 lg:grid-cols-3">
        {
          betaPlans.map((plan) => (
            <article class="flex h-full flex-col rounded-2xl border border-border bg-surface p-6 shadow-sm">
              <p class="text-lg font-semibold text-text">{plan.name}</p>
              <p class="mt-2 text-sm font-semibold text-primary">{plan.target}</p>
              <p class="mt-5 min-h-28 text-pretty text-sm leading-7 text-text-muted">
                {plan.description}
              </p>
              <div class="mt-6">
                <p class="text-3xl font-bold tabular-nums text-text">{plan.price}</p>
              </div>
              <ul class="mt-7 flex-1 space-y-3 text-sm text-text-muted">
                {plan.features.map((feature) => (
                  <li class="flex gap-3">
                    <Icon name="lucide:check" class="mt-0.5 size-4 shrink-0 text-primary" />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
              <a
                href={plan.href}
                target="_blank"
                rel="noreferrer"
                class="cta-primary mt-8 w-full text-sm"
              >
                {plan.cta}
              </a>
            </article>
          ))
        }
      </div>
      <p class="mx-auto mt-6 max-w-3xl text-center text-sm leading-7 text-text-muted text-pretty">
        いずれもベータ版として検証中の提供条件です。利用範囲・チーム規模・サポート内容に応じて個別にご案内します。
      </p>
    </div>
  </section>

  <section class="bg-surface py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-primary">開発ロードマップ（予定）</p>
        <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
          正式リリースに向けた機能開発予定
        </h2>
        <p class="mt-4 text-lg leading-8 text-text-muted text-pretty">
          以下の機能は開発ロードマップに含まれています。ベータ利用者のフィードバックをもとに、優先度を決定しています。
        </p>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {
          plannedFeatures.map((feature) => (
            <div class="flex gap-3 rounded-2xl border border-border bg-background p-5">
              <Icon name="lucide:sparkles" class="mt-0.5 size-5 shrink-0 text-primary" />
              <p class="text-sm leading-7 text-text-muted text-pretty">{feature}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-primary">ご案内</p>
        <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
          どのような方に合っているか
        </h2>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {
          selectionGuides.map((guide) => (
            <article class="rounded-2xl border border-border bg-surface p-6">
              <p class="text-sm font-semibold text-primary">{guide.condition}</p>
              <h3 class="mt-2 text-xl font-semibold text-text">{guide.recommendation}</h3>
              <p class="mt-3 text-pretty leading-7 text-text-muted">{guide.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <h2 class="text-2xl font-bold text-balance text-text sm:text-3xl">よくある質問</h2>
      </div>
      <div class="space-y-4">
        {
          pricingFaqs.map((faq) => (
            <details class="group rounded-2xl border border-border bg-surface">
              <summary class="flex cursor-pointer list-none items-center justify-between p-5 transition-colors hover:bg-surface/80 [&::-webkit-details-marker]:hidden">
                <span class="pr-4 font-medium text-text">{faq.question}</span>
                <span class="shrink-0 text-text-muted transition-transform group-open:rotate-180">
                  <Icon name="lucide:chevron-down" class="size-5" />
                </span>
              </summary>
              <div class="px-5 pb-5 text-pretty leading-7 text-text-muted">{faq.answer}</div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-surface py-section">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl border border-border bg-background p-8 sm:p-10">
        <p class="text-sm font-semibold text-primary">導入フロー</p>
        <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
          お問い合わせから利用開始まで、3ステップで進みます。
        </h2>
        <ol class="mt-8 grid gap-4 lg:grid-cols-3">
          {
            onboardingSteps.map((step, index) => (
              <li class="rounded-2xl border border-border bg-surface p-5">
                <p class="text-sm font-semibold text-primary">STEP {index + 1}</p>
                <h3 class="mt-2 text-lg font-semibold text-text">{step.title}</h3>
                <p class="mt-2 text-pretty text-sm leading-7 text-text-muted">{step.body}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>

  <section class="bg-background py-section">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div
        class="rounded-3xl border border-border bg-surface p-8 sm:p-10 lg:flex lg:items-end lg:justify-between lg:gap-8"
      >
        <div class="max-w-2xl">
          <p class="text-sm font-semibold text-primary">次の一歩</p>
          <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
            自分たちの案件で使えるか、まずはご相談ください。
          </h2>
          <p class="mt-4 text-pretty text-lg leading-8 text-text-muted">
            実際の案件内容をお聞かせいただければ、どのようにお使いいただけるかを個別にご案内します。
          </p>
        </div>
        <a href={contactUrl} target="_blank" rel="noreferrer" class="cta-primary mt-8 lg:mt-0">
          Team Betaについて相談する
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
