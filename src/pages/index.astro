---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import AgitationSection from '@/components/sections/marketing/AgitationSection.astro';
import ProductShowcase from '@/components/sections/marketing/ProductShowcase.astro';
import SocialProofSection from '@/components/sections/marketing/SocialProofSection.astro';
import FloatingCTA from '@/components/sections/marketing/FloatingCTA.astro';
import ServiceMessageSection from '@/components/sections/marketing/ServiceMessageSection.astro';
import ColumnPromoSection from '@/components/sections/marketing/ColumnPromoSection.astro';
import { featuredColumnArticles } from '@/config';
import { corCta } from '@/lib/cor-cta';

const heroPrimaryUrl = corCta.teamBeta('grift-lp-hero');
const heroSecondaryUrl = corCta.teamBeta('grift-lp-hero-secondary');
const midCtaUrl = corCta.teamBeta('grift-lp-mid');
const finalCtaUrl = corCta.teamBeta('grift-lp-final');

const pains = [
  {
    title: '曖昧な相談のまま見積を求められる',
    body: '前提条件や対象範囲が揃わないまま、金額だけを先に求められる。何を含め、何を含めないかが整理されないと、後から認識のずれが生まれます。',
  },
  {
    title: '追加要件で金額と工数が膨らむ',
    body: '要件追加や仕様変更の境界が曖昧なまま進むと、当初の見積と実際の作業に差が生まれます。変更条件を事前に共有できないことが、赤字や不信につながります。',
  },
  {
    title: '無料の調査・提案が積み上がる',
    body: 'ヒアリング、調査、複数案の検討に時間をかけても、受注につながらなければ負担だけが残ります。相談段階でどこまで扱うかを判断する材料が必要です。',
  },
  {
    title: 'なぜこの金額か説明できない',
    body: '自社の実績や市場相場を並べて説明できないと、安く出すか高く見えるかの二択になりがちです。価格の根拠をチームで確認できる状態が求められます。',
  },
];

const outcomes = [
  {
    title: '前提とやらないことを整理する',
    body: '相談内容、対象範囲、不確実な要素、やらないことを整理し、見積の出発点をチームで確認しやすくします。',
  },
  {
    title: '変更条件とリスクを可視化する',
    body: '技術的な不確実性や追加要件の可能性を整理し、どの条件で再見積もりが必要になるかを説明しやすくします。',
  },
  {
    title: '相談段階の判断材料を整える',
    body: '案件にかける調査・提案の深さを検討し、受けるべき案件か、次の確認が必要な案件かをチームで判断しやすくします。',
  },
  {
    title: '実績と相場を根拠として残す',
    body: 'GitHub実績、市場相場、類似案件、レビュー内容を見積根拠として残し、次の案件で再利用しやすい会社資産へ変えていきます。',
  },
];

const proofPillars = [
  {
    title: '1. GitHub実績の参照',
    body: 'GitHub上の開発履歴や実装傾向を、見積根拠の参考材料として整理します。「実績があります」だけでなく、提案時に説明しやすい材料へ変換することを目指します。',
  },
  {
    title: '2. 市場相場の参考比較',
    body: '一般的な受託開発の市場データや類似案件を参考に、価格帯を検討するための情報として整理します。相場や金額を保証するものではありません。',
  },
  {
    title: '3. 見積レポート生成',
    body: '案件前提、自社実績、市場相場、技術リスクを並べた参考レポートを作成します。提案前の確認や、チーム内レビューの材料として活用できます。',
  },
];

const flowSteps = [
  {
    step: '01',
    title: '相談内容とやらないことを入力',
    body: '相談内容、対象機能、納期、技術前提、現時点で扱わない範囲を入力し、見積の前提を整理します。',
  },
  {
    step: '02',
    title: '前提・スコープ・不確実性を整理',
    body: '要件の不足、追加確認が必要な点、仕様変更の可能性を整理し、比較できる状態を作ります。',
  },
  {
    step: '03',
    title: 'AIが参考見積と根拠を提示',
    body: 'AIが案件前提・自社実績・市場相場をもとに、参考見積と見積根拠を整理します。',
  },
  {
    step: '04',
    title: '人間がレビューし、最終判断',
    body: 'Griftの出力は参考情報です。担当者が内容を確認し、微調整したうえで、責任を持って見積を判断します。',
  },
  {
    step: '05',
    title: 'ノウハウとして蓄積・共有',
    body: 'レビュー内容や見積根拠を残し、次回以降の案件で再利用しやすいチームナレッジとして蓄積します。',
  },
];

const scenarios = [
  {
    label: '2〜10人の受託チーム',
    title: '「見積はあの人に聞いて」を減らしたい。',
    situation:
      '受注を増やしたいのに、見積を作れるのは代表や経験豊富な上流メンバーだけ。他のメンバーが案件相談を受けても、金額判断は持ち帰りになってしまう。',
    support:
      '案件前提、GitHub実績、市場相場、技術リスクを整理し、チームで確認できる見積根拠として残します。',
    outcome:
      '代表や一部メンバーに依存しすぎない見積プロセスを作り、PMや営業も提案前の判断材料を持ちやすくなります。',
  },
  {
    label: 'フリーランス開発者',
    title: '案件は来る。でも見積の根拠説明がつらい。',
    situation:
      '紹介や既存顧客から相談は来るものの、毎回スプレッドシートと記憶を頼りに見積を作っている。相場感はあるが、発注者に説明する資料としては残りにくい。',
    support:
      '案件前提、市場相場、過去実績を整理し、提案前に確認できる参考見積と根拠メモを作成します。',
    outcome: '見積の説明材料を用意しやすくなり、価格交渉や提案前の不安を減らしやすくなります。',
  },
  {
    label: '発注企業 / Estimate Audit',
    title: '提出された見積の前提を整理したい。',
    situation:
      'AI開発やシステム開発の見積を受け取ったが、金額の前提、技術リスク、工数妥当性を社内で説明しにくい。',
    support:
      '提出された見積の前提や技術リスク、工数妥当性を検討するための判断材料として、AIと実装者の視点で整理します。',
    outcome:
      '相見積もりや稟議前の確認材料として、どこを質問すべきか、どの前提を確認すべきかを整理しやすくなります。',
  },
];

const betaAccessInfo = [
  {
    name: 'Grift Team Beta',
    target: '2〜10人の受託チーム',
    price: '月額5万円を基本に個別案内',
    description:
      'チーム内で、担当者に依存しすぎない見積プロセスを作るためのプランです。利用範囲・チーム規模・サポート内容に応じて個別にご案内します。',
    cta: 'Team Betaについて相談する',
    href: corCta.teamBeta('grift-lp-pricing-team-beta'),
    detailHref: '/team-beta/',
    detailLabel: 'Team Beta の詳細',
  },
  {
    name: 'Grift Paid Trial',
    target: '小規模受託チーム',
    price: '3ヶ月15万円を基本に個別案内',
    description:
      'まずは実際のプロジェクトで、見積根拠の整理とナレッジ蓄積を試してみたいチーム向けのトライアルプランです。利用範囲・サポート内容に応じて個別にご案内します。',
    cta: '有料トライアルを相談する',
    href: corCta.paidTrial('grift-lp-pricing-paid-trial'),
    detailHref: '/pricing/',
    detailLabel: '料金の全体像',
  },
  {
    name: 'Grift Estimate Audit',
    target: '発注企業',
    price: '100万円を基本に個別見積',
    description:
      '提出された見積もりの妥当性を検討するための判断材料として、AIと実装者の視点で、見積の前提・技術リスク・工数妥当性を整理します。',
    cta: 'Estimate Auditについて相談する',
    href: corCta.estimateAudit('grift-lp-pricing-estimate-audit'),
    detailHref: '/estimate-audit/',
    detailLabel: 'Estimate Audit の詳細',
  },
];

const faqPreview = [
  {
    q: 'AIが見積金額を決めるのですか？',
    a: 'いいえ。AIは参考見積と見積根拠を整理する支援ツールです。最終的な見積金額の決定は人間が行います。',
  },
  {
    q: '最終判断は誰が行いますか？',
    a: '最終的な見積金額の決定は人間が行います。AIが整理した材料をもとに、担当者が責任を持って確認・調整します。',
  },
  {
    q: '料金はいくらですか？',
    a: 'Team Betaは月額5万円を基本に個別案内しています。利用範囲・チーム規模・サポート内容に応じてご案内します。',
  },
];

const heroColumnArticles = featuredColumnArticles.map((article) => ({
  ...article,
  displayTitle: article.landingTitle ?? article.title,
  displayCategory: article.landingCategory ?? article.category,
}));
---

<MarketingLayout
  title="Grift｜受託開発チームのAI見積支援ツール"
  titleTag="Grift｜見積を、勘から根拠へ。"
  ogTitle="見積を、勘から根拠へ。｜Grift"
  description="Griftは、受託開発チームが「なぜこの金額なのか」を説明できるよう、参考見積と見積根拠を整理するAI見積支援ツールです。AIに丸投げせず、人間が確認・判断できる提案材料を増やします。"
  faqItems={faqPreview.map((item) => ({ question: item.q, answer: item.a }))}
>
  <section id="hero" class="section-animate bg-background">
    <div class="landing-container py-12 sm:py-16 md:py-20 lg:py-24">
      <div class="mx-auto flex max-w-5xl flex-col items-center gap-5 text-center sm:gap-7">
        <p class="section-kicker">見積を、勘から根拠へ。</p>
        <h1
          class="type-heading text-[clamp(2.25rem,7vw,5.75rem)] font-semibold leading-[1.05] text-text"
        >
          <span class="block">なぜこの金額か、チームで説明できる。</span>
          <span class="block">受託開発のためのAI見積支援ツール</span>
        </h1>
        <div class="type-copy max-w-3xl space-y-3 text-lg text-text-muted sm:text-xl">
          <p>
            Griftは、GitHub実績・市場相場・案件前提をもとに、参考見積と見積根拠を整理するAI見積支援ツールです。
          </p>
          <p>
            AIに見積を丸投げするのではなく、人間が責任を持って確認し、説明できる提案材料を増やします。
          </p>
        </div>
        <div class="flex w-full flex-col items-center gap-3 sm:w-auto sm:flex-row">
          <a
            href={heroPrimaryUrl}
            target="_blank"
            rel="noreferrer"
            class="cta-primary w-full sm:w-auto"
          >
            Team Betaについて相談する
          </a>
          <a
            href={heroSecondaryUrl}
            target="_blank"
            rel="noreferrer"
            class="cta-secondary w-full sm:w-auto"
          >
            自分たちの案件で使えるか相談する
          </a>
        </div>
        <ul class="grid w-full gap-3 text-left text-sm text-text-muted sm:grid-cols-3">
          <li class="surface-card p-3 sm:p-4">人間レビュー前提のAI見積支援</li>
          <li class="surface-card p-3 sm:p-4">GitHub実績・市場相場を参考材料に</li>
          <li class="surface-card p-3 sm:p-4">Team Betaの利用チーム募集中</li>
        </ul>
      </div>

      <div class="mt-8 grid gap-6 sm:mt-10 lg:mt-12 lg:grid-cols-[1.05fr_0.95fr] lg:items-stretch">
        <figure
          id="product-demo"
          class="surface-panel overflow-hidden p-0"
          aria-label="Grift インテークワークスペースの画面例"
        >
          <div class="bg-surface p-3 sm:p-4">
            <img
              src="/images/grift-intake-workspace.png"
              alt="Griftのインテークワークスペース。会社情報の入力と案件管理を一か所で行う画面例"
              width="1426"
              height="1103"
              class="mx-auto max-h-[34rem] w-full object-contain"
              loading="eager"
              decoding="async"
            />
          </div>
          <figcaption
            class="border-t border-border px-4 py-3 text-xs leading-6 text-text-muted sm:px-6"
          >
            Grift
            インテークワークスペース（ベータ版の画面例）。提供範囲や表示内容は検証状況により変わります。
          </figcaption>
        </figure>

        <aside class="surface-card p-5 sm:p-6 lg:p-8">
          <p class="section-kicker">見積の考え方を先に読む</p>
          <h2 class="mt-3 type-heading text-2xl font-semibold text-text">
            相談の前提を整え、見積の根拠につなげる。
          </h2>
          <p class="mt-4 type-copy text-sm text-text-muted">
            Griftは、インテークで案件の前提・スコープ・不確実性を整理し、提案前に確認すべき材料をチームで共有しやすくします。
          </p>
          <div class="mt-6 grid gap-3">
            {
              heroColumnArticles.map((article) => (
                <a
                  href={article.href}
                  class="group rounded-2xl border border-border bg-background p-4 no-underline transition duration-200 ease-out hover:-translate-y-1 hover:border-primary/40"
                >
                  <p class="text-xs font-semibold text-primary">{article.displayCategory}</p>
                  <p class="mt-1 type-heading text-sm font-semibold text-text group-hover:text-primary">
                    {article.displayTitle}
                  </p>
                </a>
              ))
            }
          </div>
          <a
            href="/column/"
            class="mt-5 inline-flex text-sm font-semibold text-primary hover:underline"
          >
            コラムを読む →
          </a>
        </aside>
      </div>
    </div>
  </section>
  <div class="hero-accent-line" aria-hidden="true"></div>

  <ServiceMessageSection />

  <section
    id="problem"
    class="section-animate mx-auto max-w-7xl px-4 py-16 sm:px-6 md:py-24 lg:px-8"
  >
    <div class="fade-in-section max-w-3xl space-y-4">
      <p class="text-sm font-semibold text-primary">課題</p>
      <h2 class="max-w-2xl text-3xl font-semibold leading-[1.18] text-text sm:text-4xl">
        曖昧な相談を、そのまま見積にしていませんか？
      </h2>
      <p class="text-lg leading-8 text-text-muted text-pretty">
        無料の調査や追加要件で見積が後から膨らみ、なぜその金額なのか説明しにくくなる構造を整理します。
      </p>
    </div>
    <div class="stagger-children mt-10 grid gap-6 lg:grid-cols-2 xl:grid-cols-4">
      {
        pains.map((item) => (
          <article class="card-lift rounded-2xl border border-border bg-surface p-6">
            <h3 class="text-xl font-semibold text-balance text-text">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-text-muted text-pretty">{item.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <div id="agitation" class="section-animate">
    <AgitationSection />
  </div>

  <div class="bg-text py-8 text-center">
    <a
      href={midCtaUrl}
      target="_blank"
      rel="noreferrer"
      class="font-medium text-secondary hover:underline"
    >
      → 見積根拠の整理を相談する
    </a>
  </div>

  <div class="mx-auto h-px max-w-7xl bg-border" aria-hidden="true"></div>

  <section id="value" class="section-animate border-y border-border bg-surface">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 md:py-24 lg:px-8">
      <div class="fade-in-section max-w-3xl space-y-4">
        <p class="text-sm font-semibold text-primary">価値</p>
        <h2 class="text-3xl font-semibold text-balance text-text sm:text-4xl">
          曖昧な相談と根拠のない金額を、チームで確認できる前提へ。
        </h2>
        <p class="text-lg leading-8 text-text-muted text-pretty">
          Griftは、案件の前提・スコープ・変更条件を整理し、人間が責任を持って説明できる見積根拠を増やします。
        </p>
      </div>
      <div class="stagger-children mt-10 grid gap-6 lg:grid-cols-2 xl:grid-cols-4">
        {
          outcomes.map((item) => (
            <article class="card-lift rounded-2xl border border-border bg-background p-6">
              <h3 class="text-xl font-semibold text-balance text-text">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-text-muted text-pretty">{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <div id="product" class="section-animate">
    <ProductShowcase />
  </div>

  <section
    id="proof"
    class="section-animate section-alt mx-auto max-w-7xl px-4 py-16 sm:px-6 md:py-24 lg:px-8"
  >
    <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="fade-in-section space-y-4">
        <p class="text-sm font-semibold text-primary">見積根拠を支える3つの視点</p>
        <h2 class="text-3xl font-semibold text-balance text-text sm:text-4xl">
          相場だけでも、経験だけでもない。複数の材料を重ねて判断する。
        </h2>
        <p class="text-lg leading-8 text-text-muted text-pretty">
          クライアントが本当に知りたいのは、金額そのものだけではありません。なぜその金額に至ったのか。Griftは、その「なぜ」を説明するための材料を複数の視点から整理します。
        </p>
      </div>
      <div class="stagger-children grid gap-4">
        {
          proofPillars.map((item) => (
            <article class="card-lift rounded-2xl border border-border bg-surface p-6">
              <h3 class="text-lg font-semibold text-text">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-text-muted text-pretty">{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <div class="py-8 text-center">
    <a
      href={midCtaUrl}
      target="_blank"
      rel="noreferrer"
      class="font-medium text-primary hover:underline"
    >
      → 自分たちの案件で使えるか相談する
    </a>
  </div>

  <div class="mx-auto h-px max-w-7xl bg-border" aria-hidden="true"></div>

  <section id="flow" class="section-animate border-y border-border bg-surface">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 md:py-24 lg:px-8">
      <div class="fade-in-section max-w-3xl space-y-4">
        <p class="text-sm font-semibold text-primary">ご利用の流れ</p>
        <h2 class="text-3xl font-semibold text-balance text-text sm:text-4xl">
          導入からナレッジ蓄積までのステップ
        </h2>
        <p class="text-lg leading-8 text-text-muted text-pretty">
          既存のデータを活かし、見積根拠を整理する流れをチームに組み込んでいきます。
        </p>
      </div>
      <div class="stagger-children mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-5">
        {
          flowSteps.map((item) => (
            <article class="rounded-2xl border border-border bg-background p-5">
              <p class="text-sm font-semibold text-primary tabular-nums">{item.step}</p>
              <h3 class="mt-3 text-lg font-semibold text-balance text-text">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-text-muted text-pretty">{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <div id="social-proof" class="section-animate">
    <SocialProofSection />
  </div>

  <section
    id="scenarios"
    class="section-animate mx-auto max-w-7xl px-4 py-16 sm:px-6 md:py-24 lg:px-8"
  >
    <div class="fade-in-section max-w-3xl space-y-4">
      <p class="text-sm font-semibold text-primary">利用シーン</p>
      <h2 class="text-3xl font-semibold text-balance text-text sm:text-4xl">
        チームの見積根拠を、用途に合わせて整理する。
      </h2>
      <p class="text-lg leading-8 text-text-muted text-pretty">
        Griftは、受託開発チームの見積根拠整理を主軸に、フリーランスの提案準備や発注企業の見積確認にも活用できます。
      </p>
    </div>
    <div class="stagger-children mt-10 grid gap-6 xl:grid-cols-3">
      {
        scenarios.map((item) => (
          <article class="card-lift rounded-3xl border border-border bg-surface p-6">
            <span class="rounded-full border border-border bg-background px-3 py-1 text-xs font-medium text-text-muted">
              {item.label}
            </span>
            <h3 class="mt-5 text-2xl font-semibold text-balance text-text">{item.title}</h3>
            <div class="mt-6 space-y-4">
              <div class="rounded-2xl border border-border bg-background p-4">
                <p class="text-sm font-semibold text-text">よくある状況</p>
                <p class="mt-2 text-sm leading-7 text-text-muted text-pretty">{item.situation}</p>
              </div>
              <div class="rounded-2xl border border-border bg-background p-4">
                <p class="text-sm font-semibold text-text">Griftが助けること</p>
                <p class="mt-2 text-sm leading-7 text-text-muted text-pretty">{item.support}</p>
              </div>
              <div class="rounded-2xl border border-primary/20 bg-primary/5 p-4">
                <p class="text-sm font-semibold text-text">期待できる変化</p>
                <p class="mt-2 text-sm leading-7 text-text-muted text-pretty">{item.outcome}</p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section id="pricing" class="section-animate border-y border-border bg-surface">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 md:py-24 lg:px-8">
      <div class="fade-in-section max-w-3xl space-y-4">
        <p class="text-sm font-semibold text-primary">Team Beta / Pricing</p>
        <h2 class="text-3xl font-semibold text-balance text-text sm:text-4xl">
          見積根拠を、チームの資産にするための有料β。
        </h2>
        <p class="text-lg leading-8 text-text-muted text-pretty">
          現在、Griftは受託チーム向けTeam
          Betaの提供に向けて、機能・価格・サポート範囲を検証中です。利用範囲・チーム規模・サポート内容に応じて個別にご案内します。
        </p>
      </div>
      <div class="stagger-children mt-10 grid gap-5 lg:grid-cols-3">
        {
          betaAccessInfo.map((item) => (
            <article class="card-lift flex h-full flex-col rounded-2xl border border-border bg-background p-6">
              <p class="text-lg font-semibold text-text">{item.name}</p>
              <p class="mt-2 text-sm font-semibold text-primary">{item.target}</p>
              <p class="mt-5 text-3xl font-bold tabular-nums text-text">{item.price}</p>
              <p class="mt-5 flex-1 text-sm leading-7 text-text-muted text-pretty">
                {item.description}
              </p>
              <div class="mt-7 flex flex-col gap-2">
                <a href={item.href} target="_blank" rel="noreferrer" class="cta-primary text-sm">
                  {item.cta}
                </a>
                <a
                  href={item.detailHref}
                  class="text-center text-sm font-medium text-primary hover:underline"
                >
                  {item.detailLabel}
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section
    id="faq"
    class="section-animate section-alt mx-auto max-w-7xl px-4 py-16 sm:px-6 md:py-24 lg:px-8"
  >
    <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="fade-in-section space-y-4">
        <p class="text-sm font-semibold text-primary">よくある質問</p>
        <h2 class="text-3xl font-semibold text-balance text-text sm:text-4xl">
          導入前に気になるポイントをまとめました。
        </h2>
        <p class="text-lg leading-8 text-text-muted text-pretty">
          「AIが見積金額を決めるのか」「最終判断は誰が行うのか」など、導入前に確認されやすい点を整理しています。
        </p>
        <a
          href="/faq"
          class="inline-flex items-center justify-center rounded-md border border-border bg-surface px-5 py-3 text-base font-medium text-text transition-colors hover:border-primary hover:text-primary"
        >
          FAQをすべて見る
        </a>
      </div>
      <div class="space-y-4">
        {
          faqPreview.map((item) => (
            <details class="group rounded-2xl border border-border bg-surface" open>
              <summary class="cursor-pointer list-none p-6 text-lg font-semibold text-balance text-text [&::-webkit-details-marker]:hidden">
                <h3 class="inline">{item.q}</h3>
              </summary>
              <div class="px-6 pb-6">
                <p class="text-sm leading-7 text-text-muted text-pretty">{item.a}</p>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <section id="cta" class="section-animate border-t border-border bg-surface">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 md:py-24 lg:px-8">
      <div class="fade-in-section rounded-3xl border border-border bg-background p-8 lg:p-10">
        <div class="max-w-3xl space-y-4">
          <p class="text-sm font-semibold text-primary">さあ、見積を根拠へ。</p>
          <h2 class="text-3xl font-semibold text-balance text-text sm:text-4xl">
            属人的な見積を、チームで説明できるプロセスへ。
          </h2>
          <p class="text-lg leading-8 text-text-muted text-pretty">
            現在、受託チーム向けTeam
            Betaの提供に向けて検証中です。自分たちの案件で使えるか、まずはご相談ください。
          </p>
        </div>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href={finalCtaUrl} target="_blank" rel="noreferrer" class="cta-primary">
            Team Betaについて相談する
          </a>
        </div>
        <p class="mt-4 text-sm leading-7 text-text-muted text-pretty">
          ※利用範囲・チーム規模・サポート内容に応じて個別にご案内します。
        </p>
      </div>
    </div>
  </section>

  <ColumnPromoSection />

  <FloatingCTA />
</MarketingLayout>
