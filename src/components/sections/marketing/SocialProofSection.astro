---
/**
 * SocialProofSection - Trust building section for beta stage
 *
 * @description
 * Builds trust through beta status transparency, team credentials,
 * and technology trust signals. No fake testimonials — honest beta messaging.
 *
 * @example
 * ```astro
 * <SocialProofSection />
 * ```
 */

import { Icon } from 'astro-icon/components';

interface TechSignal {
  /** Lucide icon name */
  icon: string;
  /** Technology/integration name */
  name: string;
}

const techSignals: TechSignal[] = [
  { icon: 'lucide:github', name: 'GitHub実績' },
  { icon: 'lucide:brain', name: 'ローカルLLM + クラウドAI' },
  { icon: 'lucide:bar-chart-3', name: '市場相場の参考比較' },
  { icon: 'lucide:shield-check', name: '人間レビュー前提' },
];
---

<section class="border-y border-border bg-surface">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    {/* Alpha status */}
    <div class="text-center">
      <span
        class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/5 px-4 py-2 text-sm font-medium text-primary"
      >
        <span class="size-2 rounded-full bg-primary" aria-hidden="true"></span>
        現在、プライベートベータとして提供範囲を検証中
      </span>
    </div>

    <div class="stagger-children mt-12 grid gap-8 lg:grid-cols-2">
      {/* Founder story */}
      <article class="card-lift rounded-2xl border border-border bg-background p-6">
        <p class="text-sm font-semibold text-primary">開発の背景</p>
        <h3 class="mt-3 text-xl font-semibold text-balance text-text">
          「なぜこの金額なのか？」に答えるために。
        </h3>
        <div class="mt-4 space-y-3">
          <p class="text-sm leading-7 text-text-muted text-pretty">
            受託開発の現場で、見積の根拠を聞かれて苦しい思いをした経験が、Griftの出発点です。
          </p>
          <p class="text-sm leading-7 text-text-muted text-pretty">
            経験や勘は価値があります。ただし、それが担当者の頭の中だけにある限り、発注者に渡せる説明材料にも、チームで再利用できる会社資産にもなりにくい。
          </p>
          <p class="text-sm leading-7 text-text-muted text-pretty">
            Griftでやりたいのは、見積をAIに丸投げすることではありません。人間が責任を持って説明できる根拠を増やすことです。
          </p>
          <p class="text-sm leading-7 text-text-muted text-pretty">
            担当者が根拠を持って説明しやすくなり、そのノウハウをチームの資産として残せる世界を目指して、Griftを開発しています。
          </p>
        </div>
        <div class="mt-6 flex items-center gap-4 rounded-xl border border-border bg-surface p-4">
          <img
            src="/images/profile.png"
            alt="寺田 康佑"
            width="56"
            height="56"
            class="size-14 shrink-0 rounded-full object-cover"
            loading="lazy"
          />
          <div>
            <p class="text-sm font-semibold text-text">寺田康佑 / Cor.株式会社 代表</p>
          </div>
        </div>
        <div class="mt-4 flex items-center gap-3 rounded-xl border border-border bg-surface p-4">
          <img
            src="/images/logo_with_text.png"
            alt="Cor.株式会社"
            width="40"
            height="40"
            class="size-10 shrink-0 rounded-lg object-contain"
            loading="lazy"
          />
          <div>
            <p class="text-sm font-semibold text-text">
              Backed by
              <a
                href="https://cor-jp.com"
                target="_blank"
                rel="noreferrer"
                class="text-primary underline decoration-primary/40 underline-offset-2 transition-colors hover:text-primary-dark hover:decoration-primary-dark/60"
              >
                Cor.株式会社
              </a>
            </p>
            <p class="text-xs text-text-muted">cor-jp.com</p>
          </div>
        </div>
      </article>

      {/* Technology trust signals */}
      <article class="card-lift rounded-2xl border border-border bg-background p-6">
        <p class="text-sm font-semibold text-primary">技術基盤</p>
        <h3 class="mt-3 text-xl font-semibold text-balance text-text">
          見積根拠を整理するための、AIと実装データの使い分け
        </h3>
        <p class="mt-4 text-sm leading-7 text-text-muted text-pretty">
          扱う情報の機密度に応じて、クラウドAI・ローカルLLM・GitHub実績・市場相場などを使い分け、見積根拠の整理を支援します。外部AIを利用する場合は、利用規約やデータ保存設定を確認したうえで設計します。
        </p>
        <div class="mt-6 grid grid-cols-2 gap-4">
          {
            techSignals.map((signal) => (
              <div class="flex items-center gap-3 rounded-xl border border-border bg-surface p-4">
                <div class="flex size-10 shrink-0 items-center justify-center rounded-full bg-primary/10">
                  <Icon name={signal.icon} class="size-5 text-primary" aria-hidden="true" />
                </div>
                <p class="text-sm font-medium text-text">{signal.name}</p>
              </div>
            ))
          }
        </div>
      </article>
    </div>
  </div>
</section>
