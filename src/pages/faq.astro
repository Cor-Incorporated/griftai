---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@/config';

const contactUrl = 'https://cor-jp.com/contact/';

const faqSections = [
  {
    name: 'Griftについて',
    faqs: [
      {
        question: 'Griftは何を支援しますか？',
        answer:
          'GitHub実績や市場相場、類似案件などのデータを整理し、提案前の判断材料となる「参考見積」と「見積根拠」の作成を支援します。',
      },
      {
        question: 'AIが見積金額を決めるのですか？',
        answer:
          'いいえ。AIはあくまで判断材料を整理・提示するツールです。見積のすべてをAIだけで完結させるものではありません。',
      },
      {
        question: '最終判断は誰が行いますか？',
        answer:
          '最終的な見積金額の決定は人間が行います。AIが整理した材料をもとに、担当者が責任を持ってレビューし、微調整を行います。',
      },
    ],
  },
  {
    name: '機能と使い方',
    faqs: [
      {
        question: 'GitHub連携は必須ですか？',
        answer:
          '必須ではありません。連携していただくことで、過去の実績や開発傾向を参考材料として反映しやすくなります。GitHub連携なしでも、案件前提や市場相場をもとに見積根拠の整理は可能です。',
      },
      {
        question: '市場相場はどのように扱いますか？',
        answer:
          '一般的な受託開発の市場データなどを参考に、価格帯を検討するための参考情報として提示します。金額や相場を保証するものではありません。',
      },
      {
        question: 'Team Betaでは何ができますか？',
        answer:
          '実際の案件情報をもとに見積根拠を整理し、チーム内でノウハウを蓄積するプロセスを体験いただけます。現在、最適な機能やサポート範囲を検証中です。',
      },
    ],
  },
  {
    name: '対象チーム',
    faqs: [
      {
        question: 'どのようなチームに向いていますか？',
        answer:
          '見積業務が代表や一部のベテランに集中しており、属人化を減らしたい、または見積ノウハウの共有を進めたい2〜10人程度の受託開発チームに向いています。',
      },
      {
        question: 'フリーランスでも使えますか？',
        answer:
          'はい、ご利用いただけます。ただし、Griftはチームでのナレッジ蓄積や属人化を減らすことを主眼に置いているため、Team Betaとしてご案内する機能はチーム向けが中心となります。',
      },
      {
        question: '発注企業でも使えますか？',
        answer:
          'はい。提出された見積の前提や技術リスク、工数妥当性を検討するための判断材料として整理する「Estimate Audit」プランをご用意しています。',
      },
    ],
  },
  {
    name: '導入と料金',
    faqs: [
      {
        question: '料金はいくらですか？',
        answer:
          '目安として、Grift Team Betaは月額5万円を基本に個別案内しています。ご利用範囲・チーム規模・サポート内容に応じてご案内します。',
      },
      {
        question: '機密情報や案件情報はどう扱いますか？',
        answer:
          '案件情報やGitHub連携情報は、利用範囲・保存先・アクセス権限を確認したうえで扱います。外部AIを利用する場合も、各サービスの規約、データ保存設定、学習利用の有無を確認し、必要に応じて匿名化や入力制限を行います。詳細は個別にご説明します。',
      },
      {
        question: '契約前に相談できますか？',
        answer:
          'もちろんです。現在ベータ版として提供範囲を検証中のため、まずはチームの課題や状況をヒアリングし、自分たちの案件で使えるかどうかのご相談から承っております。',
      },
    ],
  },
];

const allFaqItems = faqSections.flatMap((section) => section.faqs);
---

<MarketingLayout
  title={`よくある質問 — AI見積支援ツール ${siteConfig.name}`}
  titleTag="Griftのよくある質問｜AI見積支援と人間レビュー前提"
  ogTitle="Griftのよくある質問｜AI見積支援ツール"
  description="Griftに関するよくある質問ページです。参考見積、見積根拠、人間レビュー前提、GitHub連携、料金、機密情報の扱いなど、導入検討に必要な情報をQ&A形式でまとめています。"
  faqItems={allFaqItems}
>
  <PageHeader
    title="よくある質問"
    subtitle="AI見積支援ツール Grift について、導入前に確認されやすい内容をまとめました。"
  />

  <section class="bg-background py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      {
        faqSections.map((section) => (
          <div class="mb-12 last:mb-0">
            <h2 class="mb-6 border-b border-border pb-2 text-xl font-bold text-text">
              {section.name}
            </h2>
            <div class="space-y-4">
              {section.faqs.map((faq) => (
                <details class="group rounded-2xl border border-border bg-surface">
                  <summary class="flex cursor-pointer list-none items-center justify-between p-5 transition-colors hover:bg-surface/80 [&::-webkit-details-marker]:hidden">
                    <span class="pr-4 font-medium text-text">{faq.question}</span>
                    <span class="shrink-0 text-text-muted transition-transform group-open:rotate-180">
                      <Icon name="lucide:chevron-down" class="size-5" />
                    </span>
                  </summary>
                  <div class="px-5 pb-5 text-pretty leading-7 text-text-muted">{faq.answer}</div>
                </details>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="bg-surface py-section">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div
        class="rounded-3xl border border-border bg-background p-8 sm:p-10 lg:flex lg:items-end lg:justify-between lg:gap-8"
      >
        <div class="max-w-2xl">
          <p class="text-sm font-semibold text-primary">次の一歩</p>
          <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
            自分たちの案件で使えるか、まずはご相談ください。
          </h2>
          <p class="mt-4 text-pretty text-lg leading-8 text-text-muted">
            案件の種類やチーム体制によって最適な使い方は変わります。具体的な状況をお聞かせいただければ、Griftがどう役立つかを個別にご案内します。
          </p>
        </div>
        <a href={contactUrl} class="cta-primary mt-8 lg:mt-0" target="_blank" rel="noreferrer">
          Team Betaについて相談する
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
