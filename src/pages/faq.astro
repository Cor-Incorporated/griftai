---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@/config';

const contactUrl = 'https://cor-jp.com/contact/';

const faqSections = [
  {
    name: 'Griftについて',
    faqs: [
      {
        question: 'Griftは何ができるツールですか？',
        answer:
          '案件の相談内容をAIが整理し、GitHub実績と4つの市場調査プロバイダ（Grok, Brave, Perplexity, Gemini）のデータに基づいて、根拠付きの見積レポートを自動生成します。',
      },
      {
        question: '見積はAIが確定してくれるのですか？',
        answer:
          '最終判断は人間が行います。Griftの役割は、判断に必要な材料（市場相場、自社実績、工数内訳）を整理して提示することです。',
      },
      {
        question: '誰向けのサービスですか？',
        answer:
          'フリーランスの受託開発者や、2〜10人規模の開発チームが主な対象です。案件の見積を属人的に行っている方に特に向いています。',
      },
    ],
  },
  {
    name: '機能と使い方',
    faqs: [
      {
        question: 'GitHub連携は必須ですか？',
        answer:
          '必須ではありませんが、連携すると実績ベースの速度指標（Velocity分析）が使えるため、見積の説得力が大幅に向上します。',
      },
      {
        question: 'どんな見積が出力されますか？',
        answer:
          '市場標準価格と自社提案価格の比較レポートです。工数内訳、市場ソース、コスト削減率が一目でわかる形式で出力されます。',
      },
      {
        question: 'AIヒアリングとは何ですか？',
        answer:
          '案件の相談内容を入力すると、AIが不足情報を自動で質問し、5〜10回のやり取りで構造化された仕様書を生成する機能です。',
      },
    ],
  },
  {
    name: '導入と料金',
    faqs: [
      {
        question: '今すぐ使い始められますか？',
        answer:
          '現在はベータ版のため、まずお問い合わせいただき、案件内容や利用イメージをお伺いした上でご案内しています。',
      },
      {
        question: 'ベータ料金は今後変わりますか？',
        answer:
          '正式版リリース時に見直す可能性があります。ベータ期間中にご利用を開始された方には、移行時の優遇を検討しています。',
      },
      {
        question: '解約はいつでもできますか？',
        answer: 'はい。最低契約期間はなく、月単位でいつでも解約可能です。',
      },
    ],
  },
  {
    name: 'データとセキュリティ',
    faqs: [
      {
        question: '入力したデータはどう扱われますか？',
        answer:
          '入力された案件情報やGitHubデータをAIモデルの学習に使用することはありません。データは暗号化して保存し、お客様のアカウント内でのみ利用されます。',
      },
      {
        question: 'GitHubのコードが外部に漏れることはありますか？',
        answer:
          'GitHubから取得するのはコミット頻度やPRサイズなどのメタデータのみです。ソースコード自体を読み取ることはありません。',
      },
    ],
  },
];

const allFaqItems = faqSections.flatMap((section) => section.faqs);
---

<MarketingLayout
  title={`よくある質問 — AI見積自動化ツール ${siteConfig.name}`}
  description="Grift の機能、料金、データ方針に関するよくある質問。フリーランス・受託開発チームのAI見積自動化ツールについて、導入前に確認されやすい内容をまとめています。"
  faqItems={allFaqItems}
>
  <PageHeader
    title="よくある質問"
    subtitle="AI見積自動化ツール Grift について、導入前に確認されやすい内容をまとめました。"
  />

  <section class="bg-background py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      {
        faqSections.map((section) => (
          <div class="mb-12 last:mb-0">
            <h2 class="mb-6 border-b border-border pb-2 text-xl font-bold text-text">
              {section.name}
            </h2>
            <div class="space-y-4">
              {section.faqs.map((faq) => (
                <details class="group rounded-2xl border border-border bg-surface">
                  <summary class="flex cursor-pointer list-none items-center justify-between p-5 transition-colors hover:bg-surface/80 [&::-webkit-details-marker]:hidden">
                    <span class="pr-4 font-medium text-text">{faq.question}</span>
                    <span class="shrink-0 text-text-muted transition-transform group-open:rotate-180">
                      <Icon name="lucide:chevron-down" class="size-5" />
                    </span>
                  </summary>
                  <div class="px-5 pb-5 text-pretty leading-7 text-text-muted">{faq.answer}</div>
                </details>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="bg-surface py-section">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div
        class="rounded-3xl border border-border bg-background p-8 sm:p-10 lg:flex lg:items-end lg:justify-between lg:gap-8"
      >
        <div class="max-w-2xl">
          <p class="text-sm font-semibold text-primary">次の一歩</p>
          <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
            ここに載っていない質問がある場合は、お気軽にご相談ください。
          </h2>
          <p class="mt-4 text-pretty text-lg leading-8 text-text-muted">
            案件の種類やチーム体制によって最適な使い方は変わります。具体的な状況をお聞かせいただければ、Griftがどう役立つかを個別にご案内します。お問い合わせ内容を確認後、3営業日以内に担当者よりご連絡します。
          </p>
        </div>
        <a
          href={contactUrl}
          class="mt-8 inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 font-medium text-white transition-colors hover:bg-primary-dark lg:mt-0"
        >
          導入相談をする
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
