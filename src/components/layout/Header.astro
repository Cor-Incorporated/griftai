---
import { siteConfig } from '@/config';
import { Icon } from 'astro-icon/components';
import type { FeatureFlags } from '@/lib/types';

const { features, navigation } = siteConfig;
const { header: headerNav } = navigation;

const mainNavItems = headerNav.main.filter(
  (item) => !item.feature || features[item.feature as keyof FeatureFlags]
);

const ghostCTAs = headerNav.cta.filter((cta) => cta.variant === 'ghost');
const primaryCTA = headerNav.cta.find((cta) => cta.variant === 'primary');
const hasMobileMenu = mainNavItems.length > 0 || ghostCTAs.length > 0;
---

<header id="site-header" class="sticky top-0 z-50 border-b border-border bg-background/95">
  <nav
    class="mx-auto flex h-14 max-w-7xl items-center justify-between px-4 sm:h-16 sm:px-6 lg:px-8"
    aria-label="Main navigation"
  >
    <a href="/" class="flex items-center gap-3 text-text">
      <img
        src="/grift-mark.jpg"
        alt={`${siteConfig.name} アイコン`}
        class="size-10 rounded-sm sm:hidden"
        loading="eager"
      />
      <img
        src="/grift-wordmark.jpg"
        alt={`${siteConfig.name} ロゴ`}
        class="hidden h-10 w-auto rounded-sm sm:block"
        loading="eager"
      />
    </a>

    {
      mainNavItems.length > 0 && (
        <div class="hidden items-center gap-6 md:flex">
          {mainNavItems.map((item) => (
            <a
              href={item.href}
              target={item.href.startsWith('http') ? '_blank' : undefined}
              rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
              class="rounded-md px-2 py-1 text-sm font-medium text-text-muted transition-colors hover:text-text focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background focus:outline-none"
            >
              {item.label}
            </a>
          ))}
        </div>
      )
    }

    <div class="hidden items-center gap-4 md:flex">
      {
        ghostCTAs.map((cta) => (
          <a
            href={cta.href}
            target="_blank"
            rel="noreferrer"
            class="rounded-md px-2 py-1 text-sm font-medium text-text-muted transition-colors hover:text-text focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background focus:outline-none"
          >
            {cta.label}
          </a>
        ))
      }
      {
        primaryCTA && (
          <a
            href={primaryCTA.href}
            target="_blank"
            rel="noreferrer"
            class="rounded-md bg-primary px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-dark focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background"
          >
            {primaryCTA.label}
          </a>
        )
      }
    </div>

    <div class="flex items-center gap-3 md:hidden">
      {
        !hasMobileMenu && primaryCTA && (
          <a
            href={primaryCTA.href}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center rounded-md bg-primary px-3 py-2 text-xs font-medium text-white transition-colors hover:bg-primary-dark focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background sm:px-4 sm:text-sm"
          >
            <span class="sm:hidden">相談する</span>
            <span class="hidden sm:inline">{primaryCTA.label}</span>
          </a>
        )
      }
      {
        hasMobileMenu && (
          <button
            id="mobile-menu-button"
            type="button"
            aria-label="モバイルメニューを開く"
            aria-expanded="false"
            aria-controls="mobile-menu"
            class="rounded-md p-2 transition-colors hover:bg-surface focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background"
          >
            <Icon
              name="lucide:menu"
              id="menu-icon-open"
              class="h-6 w-6 text-text"
              aria-hidden="true"
            />
            <Icon
              name="lucide:x"
              id="menu-icon-close"
              class="hidden h-6 w-6 text-text"
              aria-hidden="true"
            />
          </button>
        )
      }
    </div>
  </nav>
</header>

{
  hasMobileMenu && (
    <div
      id="mobile-menu"
      class="fixed inset-0 z-40 hidden md:hidden"
      role="dialog"
      aria-modal="true"
      aria-label="モバイルナビゲーション"
    >
      <div id="mobile-menu-backdrop" class="absolute inset-0 bg-background/80 backdrop-blur-sm" />
      <nav
        id="mobile-menu-panel"
        class="absolute left-0 right-0 max-h-[calc(100dvh-3.5rem)] overflow-y-auto border-b border-background bg-surface shadow-lg sm:max-h-[calc(100dvh-4rem)]"
        aria-label="モバイルナビゲーション"
      >
        <div class="space-y-1 px-4 py-4">
          {mainNavItems.map((item) => (
            <a
              href={item.href}
              target={item.href.startsWith('http') ? '_blank' : undefined}
              rel={item.href.startsWith('http') ? 'noreferrer' : undefined}
              class="block rounded-md px-3 py-3 text-base font-medium text-text-muted transition-colors hover:bg-background hover:text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset"
            >
              {item.label}
            </a>
          ))}
          {mainNavItems.length > 0 && ghostCTAs.length > 0 && (
            <div class="my-2 border-t border-border" />
          )}
          {ghostCTAs.map((cta) => (
            <a
              href={cta.href}
              target="_blank"
              rel="noreferrer"
              class="block rounded-md px-3 py-3 text-base font-medium text-text-muted transition-colors hover:bg-background hover:text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset"
            >
              {cta.label}
            </a>
          ))}
          {primaryCTA && (
            <a
              href={primaryCTA.href}
              target="_blank"
              rel="noreferrer"
              class="block rounded-md bg-primary px-3 py-3 text-center text-base font-medium text-white transition-colors hover:bg-primary-dark focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset"
            >
              {primaryCTA.label}
            </a>
          )}
        </div>
      </nav>
    </div>
  )
}

<script>
  const header = document.getElementById('site-header');
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuPanel = document.getElementById('mobile-menu-panel');
  const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');

  function updateMenuPosition() {
    if (header && mobileMenuPanel) {
      const headerRect = header.getBoundingClientRect();
      mobileMenuPanel.style.top = `${headerRect.bottom}px`;
    }
  }

  function openMobileMenu() {
    updateMenuPosition();
    mobileMenu?.classList.remove('hidden');
    mobileMenuButton?.setAttribute('aria-expanded', 'true');
    menuIconOpen?.classList.add('hidden');
    menuIconClose?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeMobileMenu() {
    mobileMenu?.classList.add('hidden');
    mobileMenuButton?.setAttribute('aria-expanded', 'false');
    menuIconOpen?.classList.remove('hidden');
    menuIconClose?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  if (mobileMenuButton && mobileMenu && mobileMenuPanel && mobileMenuBackdrop) {
    mobileMenuButton.addEventListener('click', () => {
      const isExpanded = mobileMenuButton.getAttribute('aria-expanded') === 'true';
      if (isExpanded) {
        closeMobileMenu();
      } else {
        openMobileMenu();
      }
    });

    mobileMenuBackdrop.addEventListener('click', closeMobileMenu);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && mobileMenuButton.getAttribute('aria-expanded') === 'true') {
        closeMobileMenu();
        mobileMenuButton.focus();
      }
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMobileMenu);
    });
  }
</script>
