---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import FAQSection from '@sections/content/FAQSection.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@/config';

const contactUrl = 'https://cor-jp.com/contact/';

const plans = [
  {
    name: 'Solo Beta',
    price: '¥9,800',
    caption: '/ 月',
    fit: '個人の受託や紹介案件で、見積の迷いを減らしたい方向け',
    features: ['1ユーザー', '月5案件まで', '相談整理の基本フロー', '実績整理の基本表示'],
  },
  {
    name: 'Studio Beta',
    price: '¥29,800',
    caption: '/ 月',
    fit: '2-5人で、提案の理由をチームで共有したい方向け',
    features: ['5ユーザーまで', '月20案件まで', '開発実績の整理支援', '提案理由の整理支援'],
    highlighted: true,
  },
  {
    name: 'Enterprise',
    price: '要問い合わせ',
    caption: '',
    fit: '権限設計、セキュリティ要件、契約対応が必要な組織向け',
    features: ['個別見積', '導入支援', '権限設計', '契約対応'],
  },
];

const chooseGuides = [
  {
    title: '個人でまず試したい',
    body: 'Solo Beta から始めるのが自然です。毎回の見積のぶれを減らし、自分の案件で型が作れるかを確かめる段階に向いています。',
  },
  {
    title: '2-5人で提案を標準化したい',
    body: 'Studio Beta が中心です。代表だけが説明できる見積から、チームで共有できる提案理由へ変えていきたいときに向いています。',
  },
  {
    title: '導入条件を個別に詰めたい',
    body: '権限、契約、支援体制まで含めるなら Enterprise を前提にご相談ください。',
  },
];

const nextSteps = [
  '問い合わせフォームから、案件の種類やチーム規模を送る',
  '3営業日以内に、使いどころと適合プランの一次回答を受ける',
  '必要に応じて、ベータ導入またはテスター条件を個別にすり合わせる',
];

const pricingFaqs = [
  {
    question: 'この価格は正式版の価格ですか？',
    answer:
      'いいえ。現在表示しているのはベータ料金です。価格や提供範囲は、ベータ期間中に見直す場合があります。',
  },
  {
    question: '最初から課金が始まりますか？',
    answer: 'いいえ。まずは案件や使いどころを伺い、ベータとして合うかを確認する進め方です。',
  },
  {
    question: 'アルファテスター向けの無償利用はありますか？',
    answer:
      'あります。検証内容や協力範囲に応じて、無償または特別価格をご案内する可能性があります。',
  },
  {
    question: 'どのプランを選べばよいか分からないです。',
    answer:
      '会社規模よりも、誰が見積を作るか、どれだけ属人化しているか、どの頻度で案件相談が来るか、で選ぶ方が実態に合います。',
  },
];
---

<MarketingLayout
  title={`ベータ料金 - ${siteConfig.name}`}
  description="Grift Beta の料金プランと、どの人やチームがどのプランから始めるべきかの目安。"
>
  <PageHeader
    title="ベータ料金"
    subtitle="正式版の定価ではありません。まずは、どの使いどころから始めるべきかを判断しやすいように、現在のベータ料金を公開しています。"
  />

  <section class="bg-background py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div
        class="rounded-2xl border border-primary/30 bg-primary/5 p-5 text-sm leading-7 text-text-muted"
      >
        <p class="font-semibold text-text">価格表示に関する前提</p>
        <p class="mt-2">
          今の料金は <span class="font-medium text-text">ベータ料金</span>
          です。正式版の価格ではなく、アルファテスター向けの無償または特別価格も含めて運用します。
        </p>
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {
          plans.map((plan) => (
            <article
              class:list={[
                'flex h-full flex-col rounded-3xl border p-7 shadow-sm',
                plan.highlighted ? 'border-primary/40 bg-primary/5' : 'border-border bg-surface',
              ]}
            >
              <p class="text-lg font-semibold text-text">{plan.name}</p>
              <p class="mt-3 min-h-14 text-pretty text-sm leading-7 text-text-muted">{plan.fit}</p>
              <div class="mt-6">
                <p class="text-4xl font-bold tabular-nums text-text">{plan.price}</p>
                {plan.caption && <p class="mt-1 text-sm text-text-muted">{plan.caption}</p>}
              </div>
              <ul class="mt-7 flex-1 space-y-3 text-sm text-text-muted">
                {plan.features.map((feature) => (
                  <li class="flex gap-3">
                    <Icon name="lucide:check" class="mt-0.5 size-4 shrink-0 text-primary" />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
              <a
                href={contactUrl}
                class:list={[
                  'mt-8 inline-flex w-full items-center justify-center rounded-md px-5 py-3 text-sm font-medium transition-colors',
                  plan.highlighted
                    ? 'bg-primary text-white hover:bg-primary-dark'
                    : 'border border-border text-text hover:bg-background',
                ]}
              >
                {plan.name === 'Enterprise' ? '個別導入を相談する' : 'このプランで相談する'}
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-surface py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-primary">どのプランから始めるべきか</p>
        <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
          チームの大きさではなく、どこで見積に悩むかで選ぶ方が合っています。
        </h2>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {
          chooseGuides.map((guide) => (
            <article class="rounded-2xl border border-border bg-background p-6">
              <h3 class="text-xl font-semibold text-text">{guide.title}</h3>
              <p class="mt-3 text-pretty leading-7 text-text-muted">{guide.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <FAQSection
    title="料金に関する FAQ"
    subtitle="価格だけでなく、申し込みの進め方やベータ期間中の扱いも含めて、先に確認されやすい内容をまとめています。"
    faqs={pricingFaqs}
    variant="accordion"
    background="default"
  />

  <section class="bg-surface py-section">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl border border-border bg-background p-8 sm:p-10">
        <p class="text-sm font-semibold text-primary">問い合わせ後の流れ</p>
        <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
          何を送ればよくて、最初に何が進むのか。
        </h2>
        <ol class="mt-8 grid gap-4 lg:grid-cols-3">
          {
            nextSteps.map((step, index) => (
              <li class="rounded-2xl border border-border bg-surface p-5">
                <p class="text-sm font-semibold text-primary">STEP {index + 1}</p>
                <p class="mt-3 text-sm leading-7 text-text-muted text-pretty">{step}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>

  <section class="bg-background py-section">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div
        class="rounded-3xl border border-border bg-surface p-8 sm:p-10 lg:flex lg:items-end lg:justify-between lg:gap-8"
      >
        <div class="max-w-2xl">
          <p class="text-sm font-semibold text-primary">次の一歩</p>
          <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
            料金表だけで決めず、いま抱えている案件相談を前提にご相談ください。
          </h2>
          <p class="mt-4 text-pretty text-lg leading-8 text-text-muted">
            ベータ版では、料金より先に「この案件で本当に役立つか」を一緒に確認した方が早いケースが多いです。お問い合わせ内容を確認後、3営業日以内に担当者よりご連絡します。
          </p>
        </div>
        <a
          href={contactUrl}
          class="mt-8 inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 font-medium text-white transition-colors hover:bg-primary-dark lg:mt-0"
        >
          導入相談をする
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
