# =============================================================================
# Grift Landing - Environment Variables
# Copy this file to .env and adjust only when overriding defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Site Configuration (Required)
# -----------------------------------------------------------------------------

# The canonical URL of your site
SITE_URL=https://griftai.org

# Your site/brand name
SITE_NAME=Grift

# Site description for SEO and meta tags
SITE_DESCRIPTION=AI開発の見積と提案を、GitHub実績と市場証拠で支える日本市場向けベータ版インテリジェンスプラットフォーム

# Author name for meta tags and copyright
SITE_AUTHOR=Cor.inc

# -----------------------------------------------------------------------------
# Cor bridge / deploy environment (ADR-0002)
# -----------------------------------------------------------------------------

# Cor site origin used by all contact CTAs (no trailing slash preferred)
# Production: https://cor-jp.com
# Preview: Preview Cor origin (pair with corsweb Preview)
PUBLIC_COR_BASE_URL=https://cor-jp.com

# production = indexable, preview = noindex,nofollow
# Cloudflare Pages Preview can also set CF_PAGES_BRANCH (non-main => preview)
PUBLIC_SITE_ENV=production
