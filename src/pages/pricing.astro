---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@/config';

const contactUrl = 'https://cor-jp.com/contact/';

const alphaTestCard = {
  name: 'プライベートアルファテスト',
  price: '無料',
  caption: 'フィードバックと引換に早期アクセス',
  description:
    '現在アルファ開発中です。実際の案件でGriftを無料で試し、フィードバックを提供いただいた方に早期アクセス権を付与します。',
  features: [
    'AIヒアリング（仕様の構造化）',
    '基本見積レポート',
    'GitHub連携（Velocity分析）',
    '個別サポート（開発チーム直接）',
  ],
};

const plannedFeatures = [
  'マルチプロバイダ市場調査（複数AIソースによる相場クロスバリデーション）',
  'Go/No-Goスコアリング（受注判断の定量化）',
  'Linear / GitHub自動同期（承認済み見積からタスクを自動生成）',
  'チーム共有と権限管理',
];

const selectionGuides = [
  {
    condition: 'アルファテストに参加したい',
    recommendation: 'プライベートアルファテスト',
    body: '実際の案件でGriftを無料で試せます。フィードバックを通じて製品の改善にご協力いただける方を募集しています。月5案件まで対応可能です。',
  },
  {
    condition: 'チームでの導入を検討している',
    recommendation: 'お問い合わせください',
    body: '2〜10人のチームでの利用を想定しています。チーム体制や案件規模をお聞かせいただければ、アルファテストから段階的に対応をご案内します。',
  },
  {
    condition: '既存ツール（Linear, GitHub）と自動連携したい',
    recommendation: '開発予定 — ご要望をお聞かせください',
    body: 'Linear/GitHub連携は開発ロードマップに含まれています。連携したいツールやワークフローをお聞かせいただければ、優先度の検討に活用させていただきます。',
  },
];

const pricingFaqs = [
  {
    question: 'アルファテストは無料ですか？',
    answer:
      'はい。アルファテスト期間中は無料でご利用いただけます。実際の案件でGriftをお試しいただき、フィードバックを提供していただくことが参加条件です。',
  },
  {
    question: '正式リリース後の料金はどうなりますか？',
    answer:
      '正式リリース時に料金体系を設定する予定です。アルファテスト参加者には移行時の優遇を検討しています。',
  },
  {
    question: '途中でやめることはできますか？',
    answer:
      'はい。いつでもアルファテストを終了できます。データはお客様のアカウント内でのみ利用されます。',
  },
  {
    question: 'どのような案件に使えますか？',
    answer:
      '新規開発、追加開発、改修、バグ修正など、受託開発全般の見積に対応予定です。アルファ版では一部機能が限定されています。',
  },
];

const onboardingSteps = [
  {
    title: 'お問い合わせ',
    body: '現在の見積プロセスや課題をお聞かせください',
  },
  {
    title: 'アルファテストご案内',
    body: '利用イメージに合うか確認し、アクセスを提供します',
  },
  {
    title: '利用開始',
    body: '実際の案件でGriftをお試しください',
  },
];
---

<MarketingLayout
  title={`料金プラン — 受託開発・フリーランスのAI見積自動化 | ${siteConfig.name}`}
  titleTag="料金プラン — 要件定義から見積もり作成をAIツールで自動化するならGrift｜Cor株式会社"
  description="Griftは受託開発の見積もりをAIで自動化するツールです。GitHub実績と市場相場データを照合し、説明できる根拠を自動生成。属人的だった見積もり作成を標準化し、提案品質を向上させます。現在プライベートアルファテスト実施中。実際の案件で無料でお試しいただけます。"
  faqItems={pricingFaqs}
>
  <PageHeader
    title="プライベートアルファテスト"
    subtitle="現在アルファ開発中です。実際の案件でGriftを無料で試せるプライベートアルファテストにご招待します。"
  />

  <section class="bg-background py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-md">
        <article
          class="flex h-full flex-col rounded-3xl border border-primary/40 p-7 shadow-sm bg-primary/5"
        >
          <p class="text-lg font-semibold text-text">{alphaTestCard.name}</p>
          <p class="mt-3 min-h-12 text-pretty text-sm leading-7 text-text-muted">
            {alphaTestCard.description}
          </p>
          <div class="mt-6">
            <p class="text-4xl font-bold tabular-nums text-text">{alphaTestCard.price}</p>
            {
              alphaTestCard.caption && (
                <p class="mt-1 text-sm text-text-muted">{alphaTestCard.caption}</p>
              )
            }
          </div>
          <ul class="mt-7 flex-1 space-y-3 text-sm text-text-muted">
            {
              alphaTestCard.features.map((feature) => (
                <li class="flex gap-3">
                  <Icon name="lucide:check" class="mt-0.5 size-4 shrink-0 text-primary" />
                  <span>{feature}</span>
                </li>
              ))
            }
          </ul>
          <a
            href={contactUrl}
            target="_blank"
            rel="noreferrer"
            class="mt-8 inline-flex w-full items-center justify-center rounded-md bg-primary px-5 py-3 text-sm font-medium transition-colors text-white hover:bg-primary-dark"
          >
            アルファテストに申し込む
          </a>
        </article>
      </div>
    </div>
  </section>

  <section class="bg-surface py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-primary">開発ロードマップ（予定）</p>
        <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
          正式リリースに向けた機能開発予定
        </h2>
        <p class="mt-4 text-lg leading-8 text-text-muted text-pretty">
          以下の機能は開発ロードマップに含まれています。アルファテスト参加者のフィードバックを元に、優先度を決定しています。
        </p>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {
          plannedFeatures.map((feature) => (
            <div class="flex gap-3 rounded-2xl border border-border bg-background p-5">
              <Icon name="lucide:sparkles" class="mt-0.5 size-5 shrink-0 text-primary" />
              <p class="text-sm leading-7 text-text-muted text-pretty">{feature}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-primary">ご案内</p>
        <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
          どのような方に合っているか
        </h2>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {
          selectionGuides.map((guide) => (
            <article class="rounded-2xl border border-border bg-surface p-6">
              <p class="text-sm font-semibold text-primary">{guide.condition}</p>
              <h3 class="mt-2 text-xl font-semibold text-text">{guide.recommendation}</h3>
              <p class="mt-3 text-pretty leading-7 text-text-muted">{guide.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <h2 class="text-2xl font-bold text-balance text-text sm:text-3xl">よくある質問</h2>
      </div>
      <div class="space-y-4">
        {
          pricingFaqs.map((faq) => (
            <details class="group rounded-2xl border border-border bg-surface">
              <summary class="flex cursor-pointer list-none items-center justify-between p-5 transition-colors hover:bg-surface/80 [&::-webkit-details-marker]:hidden">
                <span class="pr-4 font-medium text-text">{faq.question}</span>
                <span class="shrink-0 text-text-muted transition-transform group-open:rotate-180">
                  <Icon name="lucide:chevron-down" class="size-5" />
                </span>
              </summary>
              <div class="px-5 pb-5 text-pretty leading-7 text-text-muted">{faq.answer}</div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-surface py-section">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl border border-border bg-background p-8 sm:p-10">
        <p class="text-sm font-semibold text-primary">導入フロー</p>
        <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
          お問い合わせから利用開始まで、3ステップで進みます。
        </h2>
        <ol class="mt-8 grid gap-4 lg:grid-cols-3">
          {
            onboardingSteps.map((step, index) => (
              <li class="rounded-2xl border border-border bg-surface p-5">
                <p class="text-sm font-semibold text-primary">STEP {index + 1}</p>
                <h3 class="mt-2 text-lg font-semibold text-text">{step.title}</h3>
                <p class="mt-2 text-pretty text-sm leading-7 text-text-muted">{step.body}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>

  <section class="bg-background py-section">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div
        class="rounded-3xl border border-border bg-surface p-8 sm:p-10 lg:flex lg:items-end lg:justify-between lg:gap-8"
      >
        <div class="max-w-2xl">
          <p class="text-sm font-semibold text-primary">次の一歩</p>
          <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
            まずはいま抱えている案件で、Griftを試してみませんか。
          </h2>
          <p class="mt-4 text-pretty text-lg leading-8 text-text-muted">
            料金は発生しません。実際の案件内容をお聞かせいただければ、どのようにお使いいただけるかを個別にご案内します。お問い合わせ内容を確認後、3営業日以内に担当者よりご連絡します。
          </p>
        </div>
        <a
          href={contactUrl}
          target="_blank"
          rel="noreferrer"
          class="mt-8 inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 font-medium text-white transition-colors hover:bg-primary-dark lg:mt-0"
        >
          アルファテストに申し込む
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
