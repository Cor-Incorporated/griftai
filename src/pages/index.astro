---
import MarketingLayout from '@/layouts/MarketingLayout.astro';

const pains = [
  {
    title: '見積が、いつも特定の人の判断に寄ってしまう',
    body: '案件相談のたびに値付けが変わる。メンバーに渡せる型がなく、提案の再現性が作れない。',
  },
  {
    title: 'これまでの実績を、うまく伝えきれていない',
    body: '作ってきたものはあるのに、提案では肩書きや実績一覧しか見せられず、強みが伝わりにくい。',
  },
  {
    title: '価格の理由を聞かれると、言葉に詰まる',
    body: '安すぎる提案も怖いし、高すぎる提案で失注するのも避けたい。相場と実績の両方を説明したい。',
  },
];

const outcomes = [
  {
    title: '曖昧な相談を、見積できる状態まで寄せる',
    body: '要件、体制、未知の論点を整理し、概算だけが先走る状態を減らします。',
  },
  {
    title: '提案価格に説明できる理由を残す',
    body: 'これまでの実績と市場感を並べ、なぜその価格なのかを相手に説明しやすくします。',
  },
  {
    title: '見積の属人性を下げる',
    body: '代表だけが作れる提案ではなく、チームで再現しやすい型へ寄せます。',
  },
];

const proofPillars = [
  {
    title: '1. これまでの実績',
    body: 'これまでの開発実績や継続的な取り組みから、どこまで任せられるかを見えるようにする。',
  },
  {
    title: '2. 市場感',
    body: '単一の相場感ではなく、複数ソースのレンジを並べ、後から理由を説明できるようにする。',
  },
  {
    title: '3. 見積の前提',
    body: '価格だけでなく、どこまで含めるか、どこにリスクがあるかを提案の言葉に変える。',
  },
];

const flowSteps = [
  {
    step: '01',
    title: '相談を受ける',
    body: '「まず概算がほしい」「どこから整理すべきか分からない」という曖昧な相談を受ける。',
  },
  {
    step: '02',
    title: '前提を揃える',
    body: '要件、納期、体制、抜けている論点を洗い出し、見積の土台を作る。',
  },
  {
    step: '03',
    title: '根拠を重ねる',
    body: 'これまでの実績と市場感を並べ、価格に理由を持たせる。',
  },
  {
    step: '04',
    title: '提案として渡す',
    body: '概算メモではなく、相手に説明できる提案の形へ整える。',
  },
];

const scenarios = [
  {
    label: 'ソロ開発者',
    title: '紹介案件は来るが、見積にまだ自信が持てない',
    situation:
      '夜に相談が来て、翌朝までに概算を返したい。安く受けすぎるのも、高く見せて失注するのも怖い。',
    support: '過去の開発実績と相場レンジを重ねて、無理のない提案価格の材料を先に揃えます。',
    outcome: '「なんとなくこの価格」から抜け出し、理由を持って返答しやすくなります。',
  },
  {
    label: '2-5人の受託チーム',
    title: '提案が代表頼みで、チームに渡せない',
    situation:
      '受注は増やしたいが、見積と提案の質が代表の経験に依存していて、誰でも同じ水準にはならない。',
    support: '見積の論点、実績の見せ方、価格の理由づけをチームで共有しやすい型に寄せます。',
    outcome: '提案の属人性を下げながら、顧客への説明の一貫性を保ちやすくなります。',
  },
  {
    label: '発注側 PM / CTO',
    title: '複数社の見積を比べたいが、判断材料が足りない',
    situation: '金額差は大きいのに、どこまで含まれているのか、どの提案が現実的なのかが見えづらい。',
    support: '相場、実績、前提条件の見え方を揃え、追加で確認すべき論点を整理しやすくします。',
    outcome: '価格だけではなく、遂行力と前提条件まで含めた判断がしやすくなります。',
  },
];

const pricingPreview = [
  {
    name: 'Solo Beta',
    price: '¥9,800 / 月',
    fit: '個人でまず型化したい人向け',
  },
  {
    name: 'Studio Beta',
    price: '¥29,800 / 月',
    fit: '2-5人で提案の再現性を作りたいチーム向け',
  },
  {
    name: 'Enterprise',
    price: '要問い合わせ',
    fit: '権限設計や契約対応が必要な組織向け',
  },
];

const faqPreview = [
  {
    q: 'AI がそのまま見積を確定してくれますか？',
    a: 'いいえ。最終判断は人間レビュー前提です。Grift は、その判断に必要な材料を揃える方向に寄せています。',
  },
  {
    q: 'GitHub 連携は必須ですか？',
    a: '必須ではありません。ただ、実績を提案の根拠に変えたいチームには相性が良いです。',
  },
  {
    q: '今すぐ契約や課金が始まりますか？',
    a: 'いいえ。まずは案件や使いどころを伺い、ベータとして合うかを確認する進め方です。',
  },
];
---

<MarketingLayout
  title="開発案件の見積に、説明できる理由を"
  description="Grift Beta は、これまでの実績と市場感をもとに、提案価格を説明できる状態をつくる日本向けのベータ版です。"
>
  <section id="hero" class="border-b border-border bg-background">
    <div
      class="mx-auto grid max-w-7xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8 lg:py-24"
    >
      <div class="space-y-6">
        <div
          class="inline-flex items-center rounded-full border border-border bg-surface px-4 py-1.5 text-sm font-medium text-text-muted"
        >
          フリーランスから小規模チームまで使えるベータ版
        </div>
        <div class="space-y-4">
          <h1
            class="max-w-3xl text-4xl font-semibold leading-[1.15] text-balance text-text sm:text-5xl lg:text-6xl"
          >
            これまでの実績を、見積の説得力に変える。
          </h1>
          <p class="max-w-3xl text-lg leading-8 text-text-muted text-pretty">
            Grift Beta は、これまでの実績や市場感を整理し、
            <span class="font-medium text-text">「なぜこの見積なのか」</span>
            を相手に伝えやすくするためのベータ版です。AI 導入、システム開発、DX 相談など、要件が曖昧な段階でも見積の叩き台を整えやすくします。
          </p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            href="https://cor-jp.com/contact/"
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-base font-medium text-white transition-colors hover:bg-primary-dark"
          >
            自分たちの案件で使えるか相談する
          </a>
        </div>
        <div class="grid gap-3 text-sm text-text-muted sm:grid-cols-3">
          <div class="rounded-xl border border-border bg-surface px-4 py-3">
            実績を伝えやすくする
          </div>
          <div class="rounded-xl border border-border bg-surface px-4 py-3">
            価格の理由を言語化する
          </div>
          <div class="rounded-xl border border-border bg-surface px-4 py-3">
            見積の属人化を減らす
          </div>
        </div>
      </div>

      <aside class="rounded-3xl border border-border bg-surface p-6 lg:p-8">
        <p class="text-sm font-semibold text-primary">こんな相談が来たときに使う</p>
        <div class="mt-4 rounded-2xl border border-border bg-background p-5">
          <p class="text-sm leading-7 text-text-muted text-pretty">
            「まだ要件は固まり切っていないのですが、まず概算感を知りたいです」
          </p>
        </div>
        <div class="mt-6 space-y-3">
          <div class="rounded-2xl border border-border bg-background p-4">
            <p class="text-sm font-semibold text-text">確認したい論点</p>
            <p class="mt-2 text-sm text-text-muted text-pretty">
              何が未確定で、どこまでを今回の見積に含めるか。
            </p>
          </div>
          <div class="rounded-2xl border border-border bg-background p-4">
            <p class="text-sm font-semibold text-text">価格の根拠</p>
            <p class="mt-2 text-sm text-text-muted text-pretty">
              これまでの実績と市場感を並べ、なぜその価格になるかを説明できる状態にする。
            </p>
          </div>
          <div class="rounded-2xl border border-primary/20 bg-primary/5 p-4">
            <p class="text-sm font-semibold text-text">返せるアウトプット</p>
            <p class="mt-2 text-sm text-text-muted text-pretty">
              ただの概算ではなく、顧客と話を進めやすい提案の土台。
            </p>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section id="problem" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="max-w-3xl space-y-4">
      <p class="text-sm font-semibold text-primary">こんな悩みがある方へ</p>
      <h2 class="text-3xl font-semibold text-balance text-text sm:text-4xl">
        見積の作り方より、見積の説明のしかたに困っている方へ。
      </h2>
      <p class="text-lg leading-8 text-text-muted text-pretty">
        必要なのは機能の説明より、見積で迷う場面を減らせることです。Grift
        は、実績を伝えにくい、見積が属人化している、価格の理由を説明しづらい、という課題に寄り添います。
      </p>
    </div>
    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {
        pains.map((item) => (
          <article class="rounded-2xl border border-border bg-surface p-6">
            <h3 class="text-xl font-semibold text-balance text-text">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-text-muted text-pretty">{item.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section id="value" class="border-y border-border bg-surface">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="max-w-3xl space-y-4">
        <p class="text-sm font-semibold text-primary">Grift で変わること</p>
        <h2 class="text-3xl font-semibold text-balance text-text sm:text-4xl">
          概算メモを返すだけの状態から、相手に説明できる提案へ。
        </h2>
        <p class="text-lg leading-8 text-text-muted text-pretty">
          いまの段階で約束するのは、完全自動化ではありません。相談内容を整理し、実績と相場を重ね、提案価格に理由を持たせることです。
        </p>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {
          outcomes.map((item) => (
            <article class="rounded-2xl border border-border bg-background p-6">
              <h3 class="text-xl font-semibold text-balance text-text">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-text-muted text-pretty">{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="proof" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="space-y-4">
        <p class="text-sm font-semibold text-primary">見積の根拠は 3 つで作る</p>
        <h2 class="text-3xl font-semibold text-balance text-text sm:text-4xl">
          相場だけでも、自分たちの都合だけでもなく、両方を見て提案する。
        </h2>
        <p class="text-lg leading-8 text-text-muted text-pretty">
          相手が知りたいのは、価格そのものよりも「なぜその価格なのか」です。Grift
          は、根拠の置き場所を先に揃えます。
        </p>
      </div>
      <div class="grid gap-4">
        {
          proofPillars.map((item) => (
            <article class="rounded-2xl border border-border bg-surface p-6">
              <h3 class="text-lg font-semibold text-text">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-text-muted text-pretty">{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="flow" class="border-y border-border bg-surface">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="max-w-3xl space-y-4">
        <p class="text-sm font-semibold text-primary">相談から提案までの流れ</p>
        <h2 class="text-3xl font-semibold text-balance text-text sm:text-4xl">
          いきなり金額を決めるのではなく、人が判断しやすい順番で整える。
        </h2>
        <p class="text-lg leading-8 text-text-muted text-pretty">
          人が腹落ちするのは、流れが見えるときです。だから Grift
          では、相談の整理から提案の土台までを一つの線で扱います。
        </p>
      </div>
      <div class="mt-10 grid gap-4 lg:grid-cols-[1fr_auto_1fr_auto_1fr_auto_1fr]">
        {
          flowSteps.map((item, index) => (
            <>
              <article class="rounded-2xl border border-border bg-background p-5">
                <p class="text-sm font-semibold text-primary tabular-nums">{item.step}</p>
                <h3 class="mt-3 text-lg font-semibold text-balance text-text">{item.title}</h3>
                <p class="mt-3 text-sm leading-7 text-text-muted text-pretty">{item.body}</p>
              </article>
              {index < flowSteps.length - 1 && (
                <div class="hidden items-center justify-center lg:flex" aria-hidden="true">
                  <div class="flex size-10 items-center justify-center rounded-full border border-border bg-surface text-lg text-primary">
                    →
                  </div>
                </div>
              )}
            </>
          ))
        }
      </div>
    </div>
  </section>

  <section id="scenarios" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="max-w-3xl space-y-4">
      <p class="text-sm font-semibold text-primary">こんな案件相談で刺さります</p>
      <h2 class="text-3xl font-semibold text-balance text-text sm:text-4xl">
        誰が、どんな場面で、Grift を使いたくなるのか。
      </h2>
      <p class="text-lg leading-8 text-text-muted text-pretty">
        抽象的なコンセプトではなく、実際の相談場面に寄せて考える方が、購買判断は進みます。
      </p>
    </div>
    <div class="mt-10 grid gap-6 xl:grid-cols-3">
      {
        scenarios.map((item) => (
          <article class="rounded-3xl border border-border bg-surface p-6">
            <span class="rounded-full border border-border bg-background px-3 py-1 text-xs font-medium text-text-muted">
              {item.label}
            </span>
            <h3 class="mt-5 text-2xl font-semibold text-balance text-text">{item.title}</h3>
            <div class="mt-6 space-y-4">
              <div class="rounded-2xl border border-border bg-background p-4">
                <p class="text-sm font-semibold text-text">よくある状況</p>
                <p class="mt-2 text-sm leading-7 text-text-muted text-pretty">{item.situation}</p>
              </div>
              <div class="rounded-2xl border border-border bg-background p-4">
                <p class="text-sm font-semibold text-text">Grift が助けること</p>
                <p class="mt-2 text-sm leading-7 text-text-muted text-pretty">{item.support}</p>
              </div>
              <div class="rounded-2xl border border-primary/20 bg-primary/5 p-4">
                <p class="text-sm font-semibold text-text">期待できる変化</p>
                <p class="mt-2 text-sm leading-7 text-text-muted text-pretty">{item.outcome}</p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="border-y border-border bg-surface">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 py-16 sm:px-6 lg:grid-cols-[1fr_0.9fr] lg:px-8">
      <div class="space-y-4">
        <p class="text-sm font-semibold text-primary">ベータ料金</p>
        <h2 class="text-3xl font-semibold text-balance text-text sm:text-4xl">
          まずは、いまの段階に合う料金で公開する。
        </h2>
        <p class="text-lg leading-8 text-text-muted text-pretty">
          正式版の価格ではありません。アルファテスター向けの無償または特別価格も含め、まずは合う使いどころから一緒に見ます。
        </p>
      </div>
      <div class="grid gap-4">
        {
          pricingPreview.map((item) => (
            <article class="rounded-2xl border border-border bg-background p-5">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p class="text-base font-semibold text-text">{item.name}</p>
                  <p class="mt-1 text-sm text-text-muted">{item.fit}</p>
                </div>
                <p class="text-lg font-semibold tabular-nums text-text">{item.price}</p>
              </div>
            </article>
          ))
        }
        <a
          href="/pricing"
          class="inline-flex items-center justify-center rounded-md bg-primary px-5 py-3 text-base font-medium text-white transition-colors hover:bg-primary-dark"
        >
          料金と導入の考え方を見る
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="space-y-4">
        <p class="text-sm font-semibold text-primary">よくある不安</p>
        <h2 class="text-3xl font-semibold text-balance text-text sm:text-4xl">
          ベータ版だからこそ、先に答えておくべきことがあります。
        </h2>
        <p class="text-lg leading-8 text-text-muted text-pretty">
          実績を盛るよりも、何ができて何がこれからかを明確にした方が、初期の B2B
          サービスは信頼されます。
        </p>
        <a
          href="/faq"
          class="inline-flex items-center justify-center rounded-md border border-border bg-surface px-5 py-3 text-base font-medium text-text transition-colors hover:border-primary hover:text-primary"
        >
          FAQ をすべて見る
        </a>
      </div>
      <div class="space-y-4">
        {
          faqPreview.map((item) => (
            <article class="rounded-2xl border border-border bg-surface p-6">
              <h3 class="text-lg font-semibold text-balance text-text">{item.q}</h3>
              <p class="mt-3 text-sm leading-7 text-text-muted text-pretty">{item.a}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-surface">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="rounded-3xl border border-border bg-background p-8 lg:p-10">
        <div class="max-w-3xl space-y-4">
          <p class="text-sm font-semibold text-primary">最後の CTA</p>
          <h2 class="text-3xl font-semibold text-balance text-text sm:text-4xl">
            いま抱えている案件相談を、そのまま持ち込んでください。
          </h2>
          <p class="text-lg leading-8 text-text-muted text-pretty">
            まだ正式導入を決める段階でなくても構いません。まずは、
            「この案件で使えるのか」「どのプランから始めるべきか」を一緒に整理します。
          </p>
        </div>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="https://cor-jp.com/contact/"
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-base font-medium text-white transition-colors hover:bg-primary-dark"
          >
            自分たちの案件で使えるか相談する
          </a>
        </div>
        <p class="mt-4 text-sm leading-7 text-text-muted text-pretty">
          お問い合わせ内容を確認後、
          <span class="font-medium text-text">3営業日以内</span>
          に担当者よりご連絡します。
        </p>
      </div>
    </div>
  </section>
</MarketingLayout>
