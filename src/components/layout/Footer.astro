---
import { siteConfig } from '@/config';
import type { FeatureFlags, NavigationItem } from '@/lib/types';

const { features, contact, navigation } = siteConfig;
const { footer } = navigation;
const currentYear = new Date().getFullYear();

const filterByFeature = (items: NavigationItem[]) =>
  items.filter((item) => !item.feature || features[item.feature as keyof FeatureFlags]);

const productLinks = filterByFeature(footer.product);
const solutionsLinks = filterByFeature(footer.solutions);
const resourcesLinks = filterByFeature(footer.resources);
const companyLinks = filterByFeature(footer.company);
const legalLinks = filterByFeature(footer.legal);
---

<footer class="border-t border-border bg-surface">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 lg:grid-cols-6 lg:gap-12">
      <div class="col-span-2 mb-4 sm:col-span-3 lg:col-span-2 lg:mb-0">
        <a href="/" class="inline-flex items-center gap-3 text-lg font-semibold text-text">
          <span
            class="flex size-10 items-center justify-center rounded-full bg-primary text-sm font-semibold text-white"
          >
            G
          </span>
          <span>{siteConfig.name}</span>
        </a>
        <p class="mt-3 max-w-xs text-sm text-text-muted text-pretty">
          {siteConfig.description}
        </p>
        <div class="mt-4 space-y-1 text-sm text-text-muted">
          <p>
            {contact.address.state}
            {contact.address.city}
            {contact.address.country}
          </p>
          <p>
            <a
              href="https://cor-jp.com/contact/"
              target="_blank"
              rel="noreferrer"
              class="transition-colors hover:text-text"
            >
              Cor株式会社の問い合わせ窓口へ
            </a>
          </p>
        </div>
      </div>

      {
        productLinks.length > 0 && (
          <div>
            <h3 class="mb-4 text-sm font-semibold text-text">Grift</h3>
            <ul class="space-y-3">
              {productLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-text-muted transition-colors hover:text-text"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      {
        solutionsLinks.length > 0 && (
          <div>
            <h3 class="mb-4 text-sm font-semibold text-text">活用領域</h3>
            <ul class="space-y-3">
              {solutionsLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-text-muted transition-colors hover:text-text"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      {
        resourcesLinks.length > 0 && (
          <div>
            <h3 class="mb-4 text-sm font-semibold text-text">案内</h3>
            <ul class="space-y-3">
              {resourcesLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-text-muted transition-colors hover:text-text"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      {
        companyLinks.length > 0 && (
          <div>
            <h3 class="mb-4 text-sm font-semibold text-text">運営会社</h3>
            <ul class="space-y-3">
              {companyLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    target={link.href.startsWith('http') ? '_blank' : undefined}
                    rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
                    class="text-sm text-text-muted transition-colors hover:text-text"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>

    <div class="mt-12 border-t border-background pt-8">
      <div
        class="flex flex-col items-center gap-4 text-center md:flex-row md:justify-between md:text-left"
      >
        <p class="text-sm text-text-muted">&copy; {currentYear} Cor株式会社. {siteConfig.name}</p>
        <div class="flex items-center gap-6">
          {
            legalLinks.map((link) => (
              <a href={link.href} class="text-sm text-text-muted transition-colors hover:text-text">
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</footer>
