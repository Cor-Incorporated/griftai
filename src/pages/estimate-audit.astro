---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@/config';
import { corCta } from '@/lib/cor-cta';

const contactUrl = corCta.estimateAudit('grift-estimate-audit-page');
const teamBetaUrl = '/team-beta/';
const pricingUrl = '/pricing/';

const valuePoints = [
  {
    title: '見積の前提を可視化する',
    body: '提出された見積に含まれる前提・除外事項・不確実性を整理し、社内で質問すべき点を明確にします。',
  },
  {
    title: '技術リスクの検討材料',
    body: 'AI と実装者の視点で技術的な論点を洗い出し、稟議や相見積もりの前に確認ポイントを揃えます。',
  },
  {
    title: '工数妥当性の整理',
    body: '金額そのものを「決める」のではなく、工数感と根拠の読み方を整理し、判断を支援します。',
  },
];

const targets = [
  'AI 開発・システム開発の見積を受け取った発注企業',
  '相見積もり前に質問リストを整えたい調達・情シス・事業部',
  '稟議前に「どこが不透明か」を社内共有したい担当者',
];

const scopeItems = [
  '見積前提の整理',
  '技術リスク確認',
  '工数妥当性の検討材料化',
  '相見積もり前の質問整理',
  '稟議前の判断材料化',
];

const faqs = [
  {
    question: '料金の目安は？',
    answer:
      'Estimate Audit は100万円を基本に個別見積です。対象見積の規模・技術領域・納期に応じてご案内します。',
  },
  {
    question: 'AI が金額の可否を決めますか？',
    answer:
      'いいえ。最終判断は発注側の責任で行います。Grift は前提・リスク・工数の検討材料を整理する支援です。',
  },
  {
    question: '受託チーム向けの Team Beta との違いは？',
    answer:
      'Team Beta は受託チームが自社の見積プロセスを整えるプランです。Estimate Audit は発注企業が受け取った見積を検討するための導線です。',
  },
];
---

<MarketingLayout
  title={`Estimate Audit — 発注企業向け見積検討支援 | ${siteConfig.name}`}
  titleTag="Estimate Audit｜提出見積の前提・リスクを整理"
  ogTitle="Estimate Audit｜発注企業向け見積検討支援"
  description="Grift Estimate Audit は発注企業向けの見積検討支援です。提出された見積の前提・技術リスク・工数妥当性を整理し、相見積もりや稟議前の判断材料を整えます。100万円を基本に個別見積。"
  faqItems={faqs}
>
  <PageHeader
    title="Estimate Audit"
    subtitle="発注企業向け。提出された見積もりの前提・技術リスク・工数妥当性を、AIと実装者の視点で整理します。"
  />

  <section class="bg-background py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
        <div class="space-y-5">
          <p class="text-sm font-semibold text-primary">発注企業向け</p>
          <h2 class="text-balance text-3xl font-bold text-text sm:text-4xl">
            「この金額で進めてよいか」を、前提から整理する。
          </h2>
          <p class="text-pretty text-lg leading-8 text-text-muted">
            Estimate Audit
            は、見積金額を自動で是非判定するサービスではありません。提出見積を読み解き、社内で確認すべき論点を判断材料として整えます。
          </p>
          <p class="text-3xl font-bold tabular-nums text-text">100万円を基本に個別見積</p>
          <p class="text-sm text-text-muted">対象範囲・技術領域・納期により個別にご案内します。</p>
          <div class="flex flex-col gap-3 sm:flex-row">
            <a href={contactUrl} target="_blank" rel="noreferrer" class="cta-primary">
              Estimate Auditについて相談する
            </a>
            <a href={pricingUrl} class="cta-secondary">料金の全体像を見る</a>
          </div>
        </div>
        <aside class="rounded-3xl border border-border bg-surface p-6 sm:p-8">
          <p class="text-sm font-semibold text-primary">対象イメージ</p>
          <ul class="mt-5 space-y-3 text-sm leading-7 text-text-muted">
            {
              targets.map((item) => (
                <li class="flex gap-3">
                  <Icon name="lucide:check" class="mt-0.5 size-4 shrink-0 text-primary" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
          <p class="mt-6 text-sm text-text-muted">
            受託チームとして Grift を導入したい場合は
            <a href={teamBetaUrl} class="font-medium text-primary hover:underline">Team Beta</a>
            をご覧ください。
          </p>
        </aside>
      </div>
    </div>
  </section>

  <section class="border-y border-border bg-surface py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-primary">価値</p>
        <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
          監査レポートで得られること
        </h2>
      </div>
      <div class="mt-8 grid gap-5 lg:grid-cols-3">
        {
          valuePoints.map((item) => (
            <article class="rounded-2xl border border-border bg-background p-6">
              <h3 class="text-lg font-semibold text-text">{item.title}</h3>
              <p class="mt-3 text-pretty text-sm leading-7 text-text-muted">{item.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-primary">支援範囲</p>
        <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
          個別案内時に確認する項目
        </h2>
      </div>
      <ul class="mt-8 grid gap-4 sm:grid-cols-2">
        {
          scopeItems.map((item) => (
            <li class="flex gap-3 rounded-2xl border border-border bg-surface p-5 text-sm leading-7 text-text-muted">
              <Icon name="lucide:check" class="mt-0.5 size-4 shrink-0 text-primary" />
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="border-y border-border bg-surface py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center text-2xl font-bold text-text sm:text-3xl">よくある質問</h2>
      <div class="mt-10 space-y-4">
        {
          faqs.map((faq) => (
            <details class="group rounded-2xl border border-border bg-background">
              <summary class="flex cursor-pointer list-none items-center justify-between p-5 [&::-webkit-details-marker]:hidden">
                <span class="pr-4 font-medium text-text">{faq.question}</span>
                <Icon
                  name="lucide:chevron-down"
                  class="size-5 shrink-0 text-text-muted transition-transform group-open:rotate-180"
                />
              </summary>
              <div class="px-5 pb-5 text-pretty leading-7 text-text-muted">{faq.answer}</div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-background py-section">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div
        class="rounded-3xl border border-border bg-surface p-8 sm:p-10 lg:flex lg:items-end lg:justify-between lg:gap-8"
      >
        <div class="max-w-2xl">
          <p class="text-sm font-semibold text-primary">次の一歩</p>
          <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
            提出見積の前提整理からご相談ください。
          </h2>
          <p class="mt-4 text-pretty text-lg leading-8 text-text-muted">
            対象の見積概要と検討の締切が分かると、Estimate Audit
            の適合範囲を具体的にご案内できます。
          </p>
        </div>
        <a href={contactUrl} target="_blank" rel="noreferrer" class="cta-primary mt-8 lg:mt-0">
          Estimate Auditについて相談する
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
