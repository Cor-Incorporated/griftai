---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import FAQSection from '@sections/content/FAQSection.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import { siteConfig } from '@/config';

const faqCategories = [
  {
    name: '向いている会社',
    faqs: [
      {
        question: 'Grift はどんな会社に向いていますか？',
        answer:
          '主な対象は、日本のソロ開発者、小規模 AI 受託チーム、受託開発会社です。特に、案件相談を整理し、見積の理由を顧客に説明しやすくしたい会社に向いています。',
      },
      {
        question: '発注側 PM / CTO にも関係ありますか？',
        answer:
          'あります。複数社の見積を比較したい、価格だけでなく前提条件や遂行力まで見たい、という発注側の判断にも役立つ考え方です。',
      },
    ],
  },
  {
    name: 'できること',
    faqs: [
      {
        question: '最初に何が返ってきますか？',
        answer:
          'いきなり確定見積が返るわけではありません。まずは案件相談を整理し、見積に必要な論点、GitHub 実績の見せ方、市場相場の根拠を揃える方向で進みます。',
      },
      {
        question: 'AI がそのまま見積を確定してくれますか？',
        answer:
          'いいえ。最終判断は人間レビュー前提です。Grift は、判断に必要な材料を揃え、提案理由を作りやすくする方向で設計しています。',
      },
      {
        question: 'GitHub 連携は必須ですか？',
        answer:
          '必須ではありません。ただし、GitHub 実績を提案の根拠に変えたいチームには相性が良いです。',
      },
    ],
  },
  {
    name: '導入と料金',
    faqs: [
      {
        question: '今すぐ契約や課金が始まりますか？',
        answer: 'いいえ。まずは案件や使いどころを伺い、ベータとして合うかを確認する進め方です。',
      },
      {
        question: '価格は固定ですか？',
        answer:
          '現在はベータ料金です。正式版の定価ではなく、ベータ期間中に価格や提供範囲を見直す場合があります。',
      },
      {
        question: 'アルファテスター向けの無償利用はありますか？',
        answer:
          'あります。検証内容や協力範囲に応じて、無償または特別価格でご案内する可能性があります。',
      },
    ],
  },
  {
    name: 'データと安全性',
    faqs: [
      {
        question: '顧客データは学習に使われますか？',
        answer:
          '無断で学習利用する前提ではありません。匿名化、opt-in、テナント分離を前提とした設計方針で扱います。',
      },
      {
        question: '機密情報の多い案件でも相談できますか？',
        answer:
          'はい。ただし初回相談では、詳細な機密情報をいきなり入力するのではなく、まずは案件タイプや課題感の粒度から始める進め方を推奨します。',
      },
      {
        question: '問い合わせ先はどこですか？',
        answer:
          '現時点では Cor.inc の問い合わせ窓口に集約しています。https://cor-jp.com/contact/ からご相談ください。',
      },
    ],
  },
];
---

<MarketingLayout
  title={`よくある質問 - ${siteConfig.name}`}
  description="Grift Beta の対象ユーザー、できること、料金、データ方針に関するよくある質問。"
>
  <PageHeader
    title="よくある質問"
    subtitle="導入前に確認されやすい内容を、購買判断に必要な観点に絞ってまとめています。"
  />

  <FAQSection categories={faqCategories} variant="accordion" background="default" />

  <section class="bg-surface py-section">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div
        class="rounded-3xl border border-border bg-background p-8 sm:p-10 lg:flex lg:items-end lg:justify-between lg:gap-8"
      >
        <div class="max-w-2xl">
          <p class="text-sm font-semibold text-primary">次の一歩</p>
          <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
            FAQ で判断しきれない場合は、 いま抱えている案件相談をそのまま共有してください。
          </h2>
          <p class="mt-4 text-pretty text-lg leading-8 text-text-muted">
            Grift
            は、全員に同じ返答を返すよりも、案件タイプやチーム体制に応じて相談した方が価値が出やすいベータ版です。お問い合わせ内容を確認後、3営業日以内に担当者よりご連絡します。
          </p>
        </div>
        <a
          href="https://cor-jp.com/contact/"
          class="mt-8 inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 font-medium text-white transition-colors hover:bg-primary-dark lg:mt-0"
        >
          導入相談をする
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
