---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import '@/styles/gmo-columns.css';
import { siteConfig } from '@/config';

const title = 'AIを活用した要件定義・自動化ツール、AI開発に関するコラム一覧';
const description =
  'AIを活用した要件定義・自動化ツールやAI開発ならCor株式会社へ。GitHub実績と市場相場データを照合し、開発見積もりに説明できる根拠を自動で作成。上流工程の効率化や費用についてもお気軽にご相談ください。コラム一覧です。';
---

<MarketingLayout title={title} description={description}>
  <section class="py-section">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="mb-12">
        <h1 class="text-4xl font-bold text-text">
          AIを活用した要件定義・自動化ツールやAI開発などに関するコラム一覧
        </h1>
      </header>

      <div class="prose prose-lg max-w-none dark:prose-invert">
        <!-- コンテンツここから -->
        <div class="l-container">
          <div id="breadcrumbs" itemscope itemtype="https://schema.org/BreadcrumbList">
            <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"
              ><a itemprop="item" href="/"><span itemprop="name">トップ</span></a><meta
                itemprop="position"
                content="1"
              />
            </span> »
            <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"
              ><span itemprop="name">コラム一覧</span><meta itemprop="position" content="2" />
            </span>
          </div>

          <div class="l-section">
            <div class="c-head-mv u-mt30 u-mb30">
              <!-- メインバナーキャッチコピーここから -->
              <h2>AIを活用した要件定義・自動化ツールやAI開発などに関するコラム一覧</h2>
              <!-- メインバナーキャッチコピーここまで -->
            </div>

            <!-- コンテンツ一覧ここから -->
            <section class="u-mt50 c-linkblock">
              <div class="u-c-a">
                <h2 class="u-mb20">AIを活用した要件定義・自動化ツールやAI開発などに関するコラム</h2>
                <ol class="c-pagelink">
                  <li>
                    <a href="/ai-tool-requirement-definition/"
                      >AIを活用した要件定義ツールで属人化を防ぐ！要件定義の進め方や必須スキル</a>
                  </li>
                  <li>
                    <a href="/automation-tool-requirement/"
                      >要件定義プロセスの自動化！ツールの仕組みや自動化ステップを解説</a>
                  </li>
                  <li>
                    <a href="/cost-ai-develop-estimate/"
                      >AI開発の見積もり費用はどう決まる？内訳や変動要因を解説</a>
                  </li>
                  <li>
                    <a href="/market-price-ai-develop/"
                      >AI開発の相場とは？見積もりに影響する開発手法や技術スタックによる違い</a>
                  </li>
                  <li>
                    <a href="/automation-ai-develop-estimate/"
                      >AI開発の見積もりを自動化！算出のメカニズムやメリットを解説</a>
                  </li>
                  <li>
                    <a href="/ai-estimate-automation/"
                      >見積もり自動化をAIで実現！人間と共存する役割分担とは</a>
                  </li>
                  <li>
                    <a href="/create-estimate-automation/"
                      >見積もり作成を自動化！ドキュメント構成や全体のフローを解説</a>
                  </li>
                  <li>
                    <a href="/basis-estimate-automation/"
                      >自動化ツールで出した見積もりの根拠は？妥当性の見極め方</a>
                  </li>
                  <li>
                    <a href="/requirement-definition-ai/"
                      >開発の上流工程を改革！要件定義にAIを導入する理由と体制づくり</a>
                  </li>
                  <li>
                    <a href="/tool-upstream-process-ai/"
                      >上流工程を効率化するAIツール！機能と選定基準を解説</a>
                  </li>
                </ol>
              </div>
            </section>
            <!-- コンテンツ一覧ここまで -->

            <!-- NAP情報ここから -->
            <section class="u-mt50 c-nap">
              <h3 class="u-mb20">AIを活用した要件定義・自動化ツールならCor株式会社</h3>
              <table class="c-table">
                <tr>
                  <th class="u-p20">会社名</th>
                  <td class="u-p20">Cor株式会社（Cor.inc）</td>
                </tr>
                <tr>
                  <th class="u-p20">所在地</th>
                  <td class="u-p20"
                    >〒810-0001 福岡県福岡市中央区天神2丁目3-10 天神パインクレスト719号</td
                  >
                </tr>
                <tr>
                  <th class="u-p20">TEL</th>
                  <td class="u-p20"><a href="tel:05017929351">050-1792-9351</a></td>
                </tr>
                <tr>
                  <th class="u-p20">メール</th>
                  <td class="u-p20"><a href="mailto:company@cor-jp.com">company@cor-jp.com</a></td>
                </tr>
                <tr>
                  <th class="u-p20">URL</th>
                  <td class="u-p20"><a href="/">https://griftai.org</a></td>
                </tr>
              </table>
            </section>
            <!-- NAP情報ここまで -->
          </div>
        </div>
        <!-- CSSここから -->
        <style is:global>
.c-head-mv { background-image: url('/images/columns/head-mv-00.jpg'); }
</style>
        <!-- CSSここまで -->
        <script is:inline type="application/ld+json" set:html={`{
          "@context": "https://schema.org",
          "@type": "CollectionPage",
          "@id": "${siteConfig.url}/column/",
          "name": "AIを活用した要件定義・自動化ツールやAI開発などに関するコラム一覧",
          "description": "AIを活用した要件定義・自動化ツールやAI開発ならCor株式会社へ。GitHub実績と市場相場データを照合し、開発見積もりに説明できる根拠を自動で作成。上流工程の効率化や費用についてもお気軽にご相談ください。コラム一覧です。",
          "image": "${siteConfig.url}/images/columns/head-mv-00.jpg",
          "publisher": {
            "@type": "Organization",
            "name": "Cor株式会社",
            "logo": {
              "@type": "ImageObject",
              "url": "${siteConfig.url}/grift-wordmark.jpg"
            }
          }
        }`} />
        <!-- コンテンツここまで -->
      </div>
    </div>
  </section>
</MarketingLayout>
