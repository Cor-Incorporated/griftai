---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import FAQSection from '@sections/content/FAQSection.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import { Icon } from 'astro-icon/components';
import { siteConfig } from '@/config';

const contactUrl = 'https://cor-jp.com/contact/';

const plans = [
  {
    name: 'Solo Beta',
    price: '¥9,800',
    caption: '/ 月',
    description: '個人やソロ開発者向け。案件整理と見積の型化を始めたい人向けです。',
    features: [
      '1ワークスペース / 1ユーザー',
      '月5案件まで',
      '基本ヒアリング整理',
      'GitHub 実績分析の基本表示',
      'メールサポート',
    ],
  },
  {
    name: 'Studio Beta',
    price: '¥29,800',
    caption: '/ 月',
    description:
      '2-5人規模の AI / Web 受託チーム向け。営業資料としての再現性を作りたいチームに最適です。',
    features: [
      '1ワークスペース / 5ユーザーまで',
      '月20案件まで',
      'GitHub / Repository Intelligence',
      'Three-Way Proposal ベータ',
      '優先サポート',
    ],
    highlighted: true,
  },
  {
    name: 'Growth Beta',
    price: '¥79,800',
    caption: '/ 月',
    description: '提案標準化や承認フローまで見据える小規模開発会社向けです。',
    features: [
      '1ワークスペース / 10ユーザーまで',
      '月50案件まで',
      'Studio Beta の全内容',
      '引き継ぎ支援の優先提供対象',
      '導入オンボーディング',
    ],
  },
  {
    name: 'Enterprise',
    price: '要問い合わせ',
    caption: '',
    description: '高いセキュリティ要件、個別導入、契約対応が必要な組織向けです。',
    features: ['個別見積', '導入支援', '権限設計', '価格ポリシー相談', '契約対応'],
  },
];

const fitGuides = [
  {
    title: 'Solo Beta が向くケース',
    body: '案件相談のたびに見積の作り方がぶれる、GitHub 実績を営業資料に変えたい、まずは一人で型化したい場合。',
  },
  {
    title: 'Studio Beta が向くケース',
    body: '小規模チームで提案の再現性を上げたい、Three-Way Proposal を使って価格説明の土台を作りたい場合。',
  },
  {
    title: 'Growth Beta / Enterprise が向くケース',
    body: '受託比率が高い、案件数が増えてきた、導入支援や運用レビュー、セキュリティ要件まで含めて整えたい場合。',
  },
];

const pricingFaqs = [
  {
    question: 'この価格は正式版の価格ですか？',
    answer:
      'いいえ。現在表示しているのはベータ料金です。価格や機能範囲は、ベータ期間中に変更される場合があります。',
  },
  {
    question: 'アルファテスター向けの無償利用はありますか？',
    answer:
      'あります。検証内容や協力範囲に応じて、無償または特別価格でご案内する可能性があります。詳細はお問い合わせください。',
  },
  {
    question: 'セルフサーブでそのまま申し込めますか？',
    answer:
      '初期リリースでは自動課金や LP 内フォームを設けません。すべて Cor.inc の問い合わせ窓口での個別案内に寄せます。',
  },
  {
    question: 'Enterprise は何が違いますか？',
    answer:
      '高いセキュリティ要件、権限設計、運用支援、契約対応など、標準プランを超える条件を個別に整理します。',
  },
];
---

<MarketingLayout
  title={`ベータ料金 - ${siteConfig.name}`}
  description="Grift Beta の料金プランとベータ提供方針。"
>
  <PageHeader
    title="ベータ料金"
    subtitle="正式版の定価ではなく、ベータ期間中の価格です。アルファテスター向けの無償または特別価格の相談も受け付けます。"
  />

  <section class="bg-background py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div
        class="rounded-2xl border border-primary/30 bg-primary/5 p-5 text-sm leading-7 text-text-muted"
      >
        <p class="font-semibold text-text">価格表示に関する注意</p>
        <p class="mt-2">
          現時点の価格は <span class="font-medium text-text">ベータ料金</span> です。機能範囲やプラン構成は、ベータ検証の結果に応じて更新される場合があります。
        </p>
      </div>

      <div class="mt-10 grid gap-6 xl:grid-cols-4">
        {
          plans.map((plan) => (
            <article
              class:list={[
                'rounded-3xl border p-7 shadow-sm',
                plan.highlighted ? 'border-primary/40 bg-primary/5' : 'border-border bg-surface',
              ]}
            >
              <p class="text-lg font-semibold text-text">{plan.name}</p>
              <p class="mt-3 min-h-18 text-pretty text-sm leading-7 text-text-muted">
                {plan.description}
              </p>
              <div class="mt-7 min-h-16">
                <p class="text-4xl font-bold tabular-nums text-text">{plan.price}</p>
                {plan.caption && <p class="mt-1 text-sm text-text-muted">{plan.caption}</p>}
              </div>
              <ul class="mt-7 space-y-3 text-sm text-text-muted">
                {plan.features.map((feature) => (
                  <li class="flex gap-3">
                    <Icon name="lucide:check" class="mt-0.5 size-4 shrink-0 text-primary" />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
              <a
                href={contactUrl}
                class:list={[
                  'mt-8 inline-flex w-full items-center justify-center rounded-md px-5 py-3 text-sm font-medium transition-colors',
                  plan.highlighted
                    ? 'bg-primary text-white hover:bg-primary-dark'
                    : 'border border-border text-text hover:bg-background',
                ]}
              >
                {plan.name === 'Enterprise' ? 'Enterprise を相談する' : 'ベータ相談をする'}
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-surface py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-primary">プランの選び方</p>
        <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
          どのプランから始めるべきか。
        </h2>
      </div>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {
          fitGuides.map((guide) => (
            <article class="rounded-2xl border border-border bg-background p-6">
              <h3 class="text-xl font-semibold text-text">{guide.title}</h3>
              <p class="mt-3 text-pretty leading-7 text-text-muted">{guide.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <FAQSection
    title="料金に関する FAQ"
    subtitle="正式版の料金ではなくベータ期間中の価格である点を前提に、よく聞かれる内容をまとめています。"
    faqs={pricingFaqs}
    variant="accordion"
    background="default"
  />

  <section class="bg-background py-section">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div
        class="rounded-3xl border border-border bg-surface p-8 sm:p-10 lg:flex lg:items-end lg:justify-between lg:gap-8"
      >
        <div class="max-w-2xl">
          <p class="text-sm font-semibold text-primary">問い合わせ</p>
          <h2 class="mt-3 text-balance text-3xl font-bold text-text sm:text-4xl">
            プラン選定に迷う場合は、案件状況を添えてご相談ください。
          </h2>
          <p class="mt-4 text-pretty text-lg leading-8 text-text-muted">
            ベータ版では、料金より先に「どの検証を行いたいか」を一緒に整理した方が早いケースが多いです。
          </p>
        </div>
        <a
          href={contactUrl}
          class="mt-8 inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 font-medium text-white transition-colors hover:bg-primary-dark lg:mt-0"
        >
          Cor.inc に問い合わせる
        </a>
      </div>
    </div>
  </section>
</MarketingLayout>
