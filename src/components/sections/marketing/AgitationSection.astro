---
/**
 * AgitationSection - PAS framework "Agitation" section
 *
 * @description
 * Shows what happens if the persona does NOTHING about their estimation problems.
 * Escalating urgency with a professional, thoughtful tone suitable for Japanese B2B.
 *
 * @example
 * ```astro
 * <AgitationSection />
 * ```
 */

interface AgitationPoint {
  /** Escalation step number */
  step: number;
  /** Point description */
  text: string;
}

const points: AgitationPoint[] = [
  {
    step: 1,
    text: '相見積もりでの説明負け',
  },
  {
    step: 2,
    text: '根拠なき値引きによる利益圧迫',
  },
  {
    step: 3,
    text: '無料の調査・提案が積み上がる',
  },
  {
    step: 4,
    text: 'スコープ変更による赤字化',
  },
];
---

<section class="grain-bg border-y border-border bg-text">
  <div class="relative z-10 mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="fade-in-section max-w-3xl space-y-4">
      <p class="text-sm font-semibold text-secondary">リスク</p>
      <h2 class="text-3xl font-semibold leading-[1.18] text-background sm:text-4xl">
        根拠の乏しい見積は、チームの成長を止める
      </h2>
      <p class="text-lg leading-8 text-background/60 text-pretty">
        説明材料の少ない見積は、価格交渉や社内説明で不利になりやすく、受注後の認識ズレや赤字リスクにもつながります。
      </p>
    </div>

    <div class="stagger-children mt-10 grid gap-6 lg:grid-cols-2 xl:grid-cols-4">
      {
        points.map((point) => (
          <article class="relative rounded-2xl border border-background/10 bg-background/5 p-6">
            <div class="mb-4 flex size-14 items-center justify-center rounded-full border border-secondary/40 bg-secondary/15 text-2xl font-bold tabular-nums text-secondary">
              {point.step}
            </div>
            <p class="text-base leading-7 text-background/80 text-pretty">{point.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
